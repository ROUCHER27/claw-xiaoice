# Example environment configuration for XiaoIce Webhook
# Copy this file to .env and update with your production values

# Proxy Configuration (IMPORTANT for local services)
# Bypass proxy for localhost and local IPs
no_proxy=localhost,127.0.0.1,::1,*.local
NO_PROXY=localhost,127.0.0.1,::1,*.local

# Server Configuration
PORT=3002

# XiaoIce Authentication
XIAOICE_ACCESS_KEY=test-key
XIAOICE_SECRET_KEY=test-secret

# Authentication Control
# Set to 'false' to disable authentication (DEVELOPMENT/TESTING ONLY)
# MUST be 'true' or unset in production
XIAOICE_AUTH_REQUIRED=true

# Timeout Configuration (milliseconds)
XIAOICE_TIMEOUT=18000

# Optional: Node.js Configuration
# NODE_ENV=production

# Video Task Service (Hybrid Architecture)
VIDEO_TASK_SERVICE_PORT=3105
VIDEO_SERVICE_INTERNAL_TOKEN=REPLACE_WITH_INTERNAL_TOKEN
VIDEO_SERVICE_ADMIN_TOKEN=REPLACE_WITH_ADMIN_TOKEN
VIDEO_SERVICE_CALLBACK_TOKEN=REPLACE_WITH_CALLBACK_TOKEN
VIDEO_PROVIDER_API_BASE_URL=https://example-provider.com
VIDEO_PROVIDER_API_KEY=REPLACE_WITH_PROVIDER_API_KEY
VIDEO_PROVIDER_MODEL_ID=CVHPZJ4LCGBMNIZULS0
VIDEO_PROVIDER_VH_BIZ_ID=REPLACE_WITH_VH_BIZ_ID
VIDEO_CALLBACK_PUBLIC_BASE_URL=https://your-public-domain.example.com

# Video Service Ngrok Configuration
# Set to 'true' to automatically start ngrok and update callback URL
VIDEO_USE_NGROK=false
