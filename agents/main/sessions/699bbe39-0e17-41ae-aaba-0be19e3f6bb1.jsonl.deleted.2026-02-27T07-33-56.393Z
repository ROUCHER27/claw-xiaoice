{"type":"message","id":"356de20f","parentId":"e454d536","timestamp":"2026-02-27T06:41:51.738Z","message":{"role":"toolResult","toolCallId":"read:8","toolName":"read","content":[{"type":"text","text":"        }\n        \n        # 如果没有指定宽高，使用当前宽高\n        if ($Width -eq 0) { $Width = $window.Width }\n        if ($Height -eq 0) { $Height = $window.Height }\n        \n        $result = [User32]::MoveWindow($window.Handle, $X, $Y, $Width, $Height, $true)\n        \n        if ($result) {\n            Write-Host \"窗口已移动到 ($X, $Y)，大小 ${Width}x${Height}\" -ForegroundColor Green\n            Write-XiaodouyaLog \"窗口移动成功\" -Level \"INFO\"\n        }\n        \n        return $result\n    }\n    catch {\n        Write-Error \"移动窗口失败: $($_.Exception.Message)\"\n        Write-XiaodouyaLog \"移动失败: $($_.Exception.Message)\" -Level \"ERROR\"\n        return $false\n    }\n}\n\n# =============================================================================\n# UI自动化 (使用UIAutomation模块或原生方法)\n# =============================================================================\n\n<#\n.SYNOPSIS\n    列出小豆芽窗口中的所有控件\n.DESCRIPTION\n    获取窗口中所有UI控件的列表\n.PARAMETER Detailed\n    显示详细信息\n#>\nfunction Get-XiaodouyaControls {\n    [CmdletBinding()]\n    param(\n        [switch]$Detailed\n    )\n    \n    Write-XiaodouyaLog \"获取控件列表...\" -Level \"DEBUG\"\n    \n    try {\n        # 检查UIAutomation模块\n        $hasUIA = Get-Module -Name"}],"isError":false,"timestamp":1772174511735}}
