{"type":"message","id":"8060d3fc","parentId":"53fe71cb","timestamp":"2026-02-27T06:34:50.291Z","message":{"role":"toolResult","toolCallId":"exec:4","toolName":"exec","content":[{"type":"text","text":"489 /home/yirongbest/.openclaw/workspace/xiaodouya_functions.ps1"}],"details":{"status":"completed","exitCode":0,"durationMs":19,"aggregated":"489 /home/yirongbest/.openclaw/workspace/xiaodouya_functions.ps1","cwd":"/home/yirongbest/.openclaw/workspace"},"isError":false,"timestamp":1772174090286}}
{"type":"message","id":"c612aa93","parentId":"8060d3fc","timestamp":"2026-02-27T06:38:38.170Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"文件只有489行，需要完成剩余部分。让我继续添加剩余功能。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"write:5","name":"write","arguments":{"path":"/home/yirongbest/.openclaw/workspace/xiaodouya_functions.ps1","content":"#Requires -Version 5.1\n#Requires -RunAsAdministrator\n<#\n.SYNOPSIS\n    小豆芽自动化控制模块 - PowerShell函数库\n.DESCRIPTION\n    提供进程管理、窗口控制、UI自动化等功能，用于控制小豆芽应用\n.NOTES\n    作者: OpenClaw\n    版本: 1.0\n    编码: UTF-8 BOM\n#>\n\n# =============================================================================\n# 配置常量\n# =============================================================================\n$script:XiaodouyaPath = \"C:\\Program Files\\xiaodouya\\新版小豆芽.exe\"\n$script:XiaodouyaProcessName = \"新版小豆芽\"\n$script:LogEnabled = $true\n$script:LogPath = \"$env:USERPROFILE\\Documents\\xiaodouya_automation.log\"\n\n# =============================================================================\n# 日志函数\n# =============================================================================\nfunction Write-XiaodouyaLog {\n    param(\n        [string]$Message,\n        [ValidateSet(\"INFO\", \"WARN\", \"ERROR\", \"DEBUG\")]\n        [string]$Level = \"INFO\"\n    )\n    \n    if (-not $script:LogEnabled) { return }\n    \n    $timestamp = Get-Date -Format \"yyyy-MM-dd HH:mm:ss\"\n    $logEntry = \"[$timestamp] [$Level] $Message\"\n    \n    try {\n        Add-Content -Path $script:LogPath -Value $logEntry -ErrorAction SilentlyContinue\n    } catch {\n        # 静默失败，不影响主功能\n    }\n}\n\n# =============================================================================\n# 进程管理\n# =============================================================================\n\n<#\n.SYNOPSIS\n    查找所有小豆芽进程\n.DESCRIPTION\n    获取所有运行中的小豆芽进程信息\n.OUTPUTS\n    System.Diagnostics.Process[]\n#>\nfunction Get-XiaodouyaProcess {\n    [CmdletBinding()]\n    param()\n    \n    Write-XiaodouyaLog \"查找小豆芽进程...\" -Level \"DEBUG\"\n    \n    try {\n        # 尝试多种方式查找进程\n        $processes = @()\n        \n        # 方式1: 通过进程名称查找\n        $processes += Get-Process -Name \"*小豆芽*\" -ErrorAction SilentlyContinue\n        \n        # 方式2: 通过窗口标题查找\n        $processes += Get-Process | Where-Object { \n            $_.MainWindowTitle -like \"*小豆芽*\" \n        } | Select-Object -Unique\n        \n        # 去重并过滤\n        $uniqueProcesses = $processes | Select-Object -Unique Id | ForEach-Object {\n            Get-Process -Id $_.Id -ErrorAction SilentlyContinue\n        } | Where-Object { $_ -ne $null }\n        \n        Write-XiaodouyaLog \"找到 $($uniqueProcesses.Count) 个小豆芽进程\" -Level \"INFO\"\n        \n        return $uniqueProcesses\n    }\n    catch {\n        Write-XiaodouyaLog \"查找进程失败: $($_.Exception.Message)\" -Level \"ERROR\"\n        return @()\n    }\n}\n\n<#\n.SYNOPSIS\n    启动小豆芽\n.DESCRIPTION\n    启动小豆芽应用程序\n.PARAMETER Wait\n    等待进程启动完成\n#>\nfunction Start-Xiaodouya {\n    [CmdletBinding()]\n    param(\n        [switch]$Wait\n    )\n    \n    Write-XiaodouyaLog \"启动小豆芽...\" -Level \"INFO\"\n    \n    try {\n        # 检查是否已运行\n        $existing = Get-XiaodouyaProcess\n        if ($existing.Count -gt 0) {\n            Write-Host \"小豆芽已在运行中 (PID: $($existing[0].Id))\" -ForegroundColor Yellow\n            Write-XiaodouyaLog \"小豆芽已在运行，PID: $($existing[0].Id)\" -Level \"WARN\"\n            return $existing[0]\n        }\n        \n        # 检查文件是否存在\n        if (-not (Test-Path $script:XiaodouyaPath)) {\n            throw \"找不到小豆芽可执行文件: $($script:XiaodouyaPath)\"\n        }\n        \n        # 启动进程\n        $process = Start-Process -FilePath $script:XiaodouyaPath -PassThru\n        \n        Write-Host \"小豆芽已启动 (PID: $($process.Id))\" -ForegroundColor Green\n        Write-XiaodouyaLog \"小豆芽启动成功，PID: $($process.Id)\" -Level \"INFO\"\n        \n        if ($Wait) {\n            Write-Host \"等待进程初始化...\"\n            Start-Sleep -Seconds 3\n        }\n        \n        return $process\n    }\n    catch {\n        Write-Error \"启动小豆芽失败: $($_.Exception.Message)\"\n        Write-XiaodouyaLog \"启动失败: $($_.Exception.Message)\" -Level \"ERROR\"\n        return $null\n    }\n}\n\n<#\n.SYNOPSIS\n    停止所有小豆芽进程\n.DESCRIPTION\n    强制结束所有小豆芽进程\n.PARAMETER Force\n    强制结束，不提示确认\n#>\nfunction Stop-Xiaodouya {\n    [CmdletBinding()]\n    param(\n        [switch]$Force\n    )\n    \n    Write-XiaodouyaLog \"停止小豆芽...\" -Level \"INFO\"\n    \n    try {\n        $processes = Get-XiaodouyaProcess\n        \n        if ($processes.Count -eq 0) {\n            Write-Host \"小豆芽未在运行\" -ForegroundColor Yellow\n            Write-XiaodouyaLog \"小豆芽未运行\" -Level \"WARN\"\n            return\n        }\n        \n        if (-not $Force) {\n            $confirm = Read-Host \"确定要结束 $($processes.Count) 个小豆芽进程吗? (Y/N)\"\n            if ($confirm -ne 'Y') {\n                Write-Host \"已取消\" -ForegroundColor Yellow\n                return\n            }\n        }\n        \n        foreach ($proc in $processes) {\n            try {\n                Stop-Process -Id $proc.Id -Force\n                Write-Host \"已结束进程 PID: $($proc.Id)\" -ForegroundColor Green\n                Write-XiaodouyaLog \"结束进程 PID: $($proc.Id)\" -Level \"INFO\"\n            }\n            catch {\n                Write-Warning \"无法结束进程 PID: $($proc.Id) - $($_.Exception.Message)\"\n                Write-XiaodouyaLog \"结束进程失败 PID: $($proc.Id) - $($_.Exception.Message)\" -Level \"ERROR\"\n            }\n        }\n    }\n    catch {\n        Write-Error \"停止小豆芽失败: $($_.Exception.Message)\"\n        Write-XiaodouyaLog \"停止失败: $($_.Exception.Message)\" -Level \"ERROR\"\n    }\n}\n\n# =============================================================================\n# 窗口控制\n# =============================================================================\n\nAdd-Type @\"\n    using System;\n    using System.Runtime.InteropServices;\n    \n    public class User32 {\n        [DllImport(\"user32.dll\")]\n        public static extern bool SetForegroundWindow(IntPtr hWnd);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern bool GetWindowRect(IntPtr hWnd, out RECT lpRect);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern bool MoveWindow(IntPtr hWnd, int X, int Y, int nWidth, int nHeight, bool bRepaint);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern IntPtr GetForegroundWindow();\n        \n        [DllImport(\"user32.dll\")]\n        public static extern int GetWindowText(IntPtr hWnd, System.Text.StringBuilder text, int count);\n        \n        [DllImport(\"user32.dll\", SetLastError = true)]\n        public static extern void keybd_event(byte bVk, byte bScan, uint dwFlags, UIntPtr dwExtraInfo);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern bool SetCursorPos(int x, int y);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern void mouse_event(uint dwFlags, uint dx, uint dy, uint dwData, int dwExtraInfo);\n        \n        public const int SW_SHOW = 5;\n        public const int SW_HIDE = 0;\n        public const int SW_MINIMIZE = 6;\n        public const int SW_MAXIMIZE = 3;\n        public const int SW_RESTORE = 9;\n        \n        public const uint KEYEVENTF_KEYUP = 0x0002;\n        public const uint MOUSEEVENTF_LEFTDOWN = 0x0002;\n        public const uint MOUSEEVENTF_LEFTUP = 0x0004;\n        \n        public struct RECT {\n            public int Left;\n            public int Top;\n            public int Right;\n            public int Bottom;\n        }\n    }\n\"@\n\n<#\n.SYNOPSIS\n    获取小豆芽窗口信息\n.DESCRIPTION\n    获取主窗口的句柄、位置、标题等信息\n.OUTPUTS\n    PSCustomObject\n#>\nfunction Get-XiaodouyaWindow {\n    [CmdletBinding()]\n    param()\n    \n    Write-XiaodouyaLog \"获取窗口信息...\" -Level \"DEBUG\"\n    \n    try {\n        $processes = Get-XiaodouyaProcess\n        if ($processes.Count -eq 0) {\n            Write-Error \"小豆芽未在运行\"\n            return $null\n        }\n        \n        # 找到有窗口的进程\n        $windowProcess = $processes | Where-Object { $_.MainWindowHandle -ne [IntPtr]::Zero } | Select-Object -First 1\n        \n        if (-not $windowProcess) {\n            Write-Error \"找不到小豆芽主窗口\"\n            return $null\n        }\n        \n        $hWnd = $windowProcess.MainWindowHandle\n        $rect = New-Object User32+RECT\n        [User32]::GetWindowRect($hWnd, [ref]$rect) | Out-Null\n        \n        $width = $rect.Right - $rect.Left\n        $height = $rect.Bottom - $rect.Top\n        \n        $result = [PSCustomObject]@{\n            ProcessId = $windowProcess.Id\n            Handle = $hWnd\n            Title = $windowProcess.MainWindowTitle\n            Left = $rect.Left\n            Top = $rect.Top\n            Width = $width\n            Height = $height\n            IsVisible = $true\n            IsForeground = ([User32]::GetForegroundWindow() -eq $hWnd)\n        }\n        \n        Write-XiaodouyaLog \"窗口信息获取成功: 位置($($rect.Left), $($rect.Top)), 大小(${width}x${height})\" -Level \"DEBUG\"\n        \n        return $result\n    }\n    catch {\n        Write-Error \"获取窗口信息失败: $($_.Exception.Message)\"\n        Write-XiaodouyaLog \"获取窗口信息失败: $($_.Exception.Message)\" -Level \"ERROR\"\n        return $null\n    }\n}\n\n<#\n.SYNOPSIS\n    激活小豆芽窗口到前台\n.DESCRIPTION\n    将小豆芽窗口带到最前面\n#>\nfunction Set-XiaodouyaActive {\n    [CmdletBinding()]\n    param()\n    \n    Write-XiaodouyaLog \"激活窗口...\" -Level \"INFO\"\n    \n    try {\n        $window = Get-XiaodouyaWindow\n        if (-not $window) {\n            Write-Error \"无法获取窗口\"\n            return $false\n        }\n        \n        # 先恢复窗口（如果最小化）\n        [User32]::ShowWindow($window.Handle, [User32]::SW_RESTORE) | Out-Null\n        \n        # 设置到前台\n        $result = [User32]::SetForegroundWindow($window.Handle)\n        \n        if ($result) {\n            Write-Host \"小豆芽窗口已激活\" -ForegroundColor Green\n            Write-XiaodouyaLog \"窗口激活成功\" -Level \"INFO\"\n        } else {\n            Write-Warning \"窗口激活可能失败（某些情况下这是正常的）\"\n            Write-XiaodouyaLog \"窗口激活返回值: $result\" -Level \"WARN\"\n        }\n        \n        return $result\n    }\n    catch {\n        Write-Error \"激活窗口失败: $($_.Exception.Message)\"\n        Write-XiaodouyaLog \"激活失败: $($_.Exception.Message)\" -Level \"ERROR\"\n        return $false\n    }\n}\n\n<#\n.SYNOPSIS\n    最小化小豆芽窗口\n.DESCRIPTION\n    将小豆芽窗口最小化到任务栏\n#>\nfunction Set-XiaodouyaMinimize {\n    [CmdletBinding()]\n    param()\n    \n    Write-XiaodouyaLog \"最小化窗口...\" -Level \"INFO\"\n    \n    try {\n        $window = Get-XiaodouyaWindow\n        if (-not $window) {\n            Write-Error \"无法获取窗口\"\n            return $false\n        }\n        \n        $result = [User32]::ShowWindow($window.Handle, [User32]::SW_MINIMIZE)\n        \n        if ($result) {\n            Write-Host \"小豆芽窗口已最小化\" -ForegroundColor Green\n            Write-XiaodouyaLog \"窗口最小化成功\" -Level \"INFO\"\n        }\n        \n        return $result\n    }\n    catch {\n        Write-Error \"最小化窗口失败: $($_.Exception.Message)\"\n        Write-XiaodouyaLog \"最小化失败: $($_.Exception.Message)\" -Level \"ERROR\"\n        return $false\n    }\n}\n\n<#\n.SYNOPSIS\n    最大化小豆芽窗口\n.DESCRIPTION\n    将小豆芽窗口最大化\n#>\nfunction Set-XiaodouyaMaximize {\n    [CmdletBinding()]\n    param()\n    \n    Write-XiaodouyaLog \"最大化窗口...\" -Level \"INFO\"\n    \n    try {\n        $window = Get-XiaodouyaWindow\n        if (-not $window) {\n            Write-Error \"无法获取窗口\"\n            return $false\n        }\n        \n        $result = [User32]::ShowWindow($window.Handle, [User32]::SW_MAXIMIZE)\n        \n        if ($result) {\n            Write-Host \"小豆芽窗口已最大化\" -ForegroundColor Green\n            Write-XiaodouyaLog \"窗口最大化成功\" -Level \"INFO\"\n        }\n        \n        return $result\n    }\n    catch {\n        Write-Error \"最大化窗口失败: $($_.Exception.Message)\"\n        Write-XiaodouyaLog \"最大化失败: $($_.Exception.Message)\" -Level \"ERROR\"\n        return $false\n    }\n}\n\n<#\n.SYNOPSIS\n    移动小豆芽窗口\n.DESCRIPTION\n    将小豆芽窗口移动到指定位置\n.PARAMETER X\n    新的X坐标\n.PARAMETER Y\n    新的Y坐标\n.PARAMETER Width\n    新的宽度（可选）\n.PARAMETER Height\n    新的高度（可选）\n#>\nfunction Move-XiaodouyaWindow {\n    [CmdletBinding()]\n    param(\n        [Parameter(Mandatory = $true)]\n        [int]$X,\n        \n        [Parameter(Mandatory = $true)]\n        [int]$Y,\n        \n        [int]$Width = 0,\n        [int]$Height = 0\n    )\n    \n    Write-XiaodouyaLog \"移动窗口到 ($X, $Y)...\" -Level \"INFO\"\n    \n    try {\n        $window = Get-XiaodouyaWindow\n        if (-not $window) {\n            Write-Error \"无法获取窗口\"\n            return $false\n        }\n        \n        # 如果没有指定宽高，使用当前宽高\n        if ($Width -eq 0) { $Width = $window.Width }\n        if ($Height -eq 0) { $Height = $window.Height }\n        \n        $result = [User32]::MoveWindow($window.Handle, $X, $Y, $Width, $Height, $true)\n        \n        if ($result) {\n            Write-Host \"窗口已移动到 ($X, $Y)，大小 ${Width}x${Height}\" -ForegroundColor Green\n            Write-XiaodouyaLog \"窗口移动成功\" -Level \"INFO\"\n        }\n        \n        return $result\n    }\n    catch {\n        Write-Error \"移动窗口失败: $($_.Exception.Message)\"\n        Write-XiaodouyaLog \"移动失败: $($_.Exception.Message)\" -Level \"ERROR\"\n        return $false\n    }\n}\n\n# =============================================================================\n# UI自动化 (使用UIAutomation模块或原生方法)\n# =============================================================================\n\n<#\n.SYNOPSIS\n    列出小豆芽窗口中的所有控件\n.DESCRIPTION\n    获取窗口中所有UI控件的列表\n.PARAMETER Detailed\n    显示详细信息\n#>\nfunction Get-XiaodouyaControls {\n    [CmdletBinding()]\n    param(\n        [switch]$Detailed\n    )\n    \n    Write-XiaodouyaLog \"获取控件列表...\" -Level \"DEBUG\"\n    \n    try {\n        # 检查UIAutomation模块\n        $hasUIA = Get-Module -Name"}},{"type":"thinking","thinking":" U","thinkingSignature":"reasoning_content"}],"api":"openai-completions","provider":"volcengine-plan","model":"kimi-k2.5","usage":{"input":16953,"output":8192,"cacheRead":0,"cacheWrite":0,"totalTokens":25145,"cost":{"input":0.0000016953,"output":0.0000016384,"cacheRead":0,"cacheWrite":0,"total":0.0000033337}},"stopReason":"length","timestamp":1772174090291}}
