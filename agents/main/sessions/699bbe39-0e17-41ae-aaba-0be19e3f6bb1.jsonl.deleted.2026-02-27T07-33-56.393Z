{"type":"message","id":"4345676a","parentId":"d386ac33","timestamp":"2026-02-27T06:41:51.659Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"exec:7","name":"exec","arguments":{"command":"wc -l /home/yirongbest/.openclaw/workspace/xiaodouya_functions.ps1"}},{"type":"toolCall","id":"read:8","name":"read","arguments":{"path":"/home/yirongbest/.openclaw/workspace/xiaodouya_functions.ps1","offset":450,"limit":50}},{"type":"toolCall","id":"write:9","name":"write","arguments":{"path":"/home/yirongbest/.openclaw/workspace/xiaodouya_functions.ps1","content":"#Requires -Version 5.1\n#Requires -RunAsAdministrator\n<#\n.SYNOPSIS\n    小豆芽自动化控制模块 - PowerShell函数库\n.DESCRIPTION\n    提供进程管理、窗口控制、UI自动化等功能，用于控制小豆芽应用\n.NOTES\n    作者: OpenClaw\n    版本: 1.0\n    编码: UTF-8 BOM\n#>\n\n# =============================================================================\n# 配置常量\n# =============================================================================\n$script:XiaodouyaPath = \"C:\\Program Files\\xiaodouya\\新版小豆芽.exe\"\n$script:XiaodouyaProcessName = \"新版小豆芽\"\n$script:LogEnabled = $true\n$script:LogPath = \"$env:USERPROFILE\\Documents\\xiaodouya_automation.log\"\n\n# =============================================================================\n# 日志函数\n# =============================================================================\nfunction Write-XiaodouyaLog {\n    param(\n        [string]$Message,\n        [ValidateSet(\"INFO\", \"WARN\", \"ERROR\", \"DEBUG\")]\n        [string]$Level = \"INFO\"\n    )\n    \n    if (-not $script:LogEnabled) { return }\n    \n    $timestamp = Get-Date -Format \"yyyy-MM-dd HH:mm:ss\"\n    $logEntry = \"[$timestamp] [$Level] $Message\"\n    \n    try {\n        Add-Content -Path $script:LogPath -Value $logEntry -ErrorAction SilentlyContinue\n    } catch {\n        # 静默失败，不影响主功能\n    }\n}\n\n# =============================================================================\n# 进程管理\n# =============================================================================\n\nfunction Get-XiaodouyaProcess {\n    [CmdletBinding()]\n    param()\n    \n    Write-XiaodouyaLog \"查找小豆芽进程...\" -Level \"DEBUG\"\n    \n    try {\n        $processes = @()\n        $processes += Get-Process -Name \"*小豆芽*\" -ErrorAction SilentlyContinue\n        $processes += Get-Process | Where-Object { $_.MainWindowTitle -like \"*小豆芽*\" } | Select-Object -Unique\n        \n        $uniqueProcesses = $processes | Select-Object -Unique Id | ForEach-Object {\n            Get-Process -Id $_.Id -ErrorAction SilentlyContinue\n        } | Where-Object { $_ -ne $null }\n        \n        Write-XiaodouyaLog \"找到 $($uniqueProcesses.Count) 个小豆芽进程\" -Level \"INFO\"\n        return $uniqueProcesses\n    }\n    catch {\n        Write-XiaodouyaLog \"查找进程失败: $($_.Exception.Message)\" -Level \"ERROR\"\n        return @()\n    }\n}\n\nfunction Start-Xiaodouya {\n    [CmdletBinding()]\n    param([switch]$Wait)\n    \n    Write-XiaodouyaLog \"启动小豆芽...\" -Level \"INFO\"\n    \n    try {\n        $existing = Get-XiaodouyaProcess\n        if ($existing.Count -gt 0) {\n            Write-Host \"小豆芽已在运行中 (PID: $($existing[0].Id))\" -ForegroundColor Yellow\n            return $existing[0]\n        }\n        \n        if (-not (Test-Path $script:XiaodouyaPath)) {\n            throw \"找不到小豆芽可执行文件: $($script:XiaodouyaPath)\"\n        }\n        \n        $process = Start-Process -FilePath $script:XiaodouyaPath -PassThru\n        Write-Host \"小豆芽已启动 (PID: $($process.Id))\" -ForegroundColor Green\n        \n        if ($Wait) {\n            Start-Sleep -Seconds 3\n        }\n        \n        return $process\n    }\n    catch {\n        Write-Error \"启动小豆芽失败: $($_.Exception.Message)\"\n        return $null\n    }\n}\n\nfunction Stop-Xiaodouya {\n    [CmdletBinding()]\n    param([switch]$Force)\n    \n    Write-XiaodouyaLog \"停止小豆芽...\" -Level \"INFO\"\n    \n    try {\n        $processes = Get-XiaodouyaProcess\n        \n        if ($processes.Count -eq 0) {\n            Write-Host \"小豆芽未在运行\" -ForegroundColor Yellow\n            return\n        }\n        \n        if (-not $Force) {\n            $confirm = Read-Host \"确定要结束 $($processes.Count) 个小豆芽进程吗? (Y/N)\"\n            if ($confirm -ne 'Y') {\n                Write-Host \"已取消\" -ForegroundColor Yellow\n                return\n            }\n        }\n        \n        foreach ($proc in $processes) {\n            try {\n                Stop-Process -Id $proc.Id -Force\n                Write-Host \"已结束进程 PID: $($proc.Id)\" -ForegroundColor Green\n            }\n            catch {\n                Write-Warning \"无法结束进程 PID: $($proc.Id) - $($_.Exception.Message)\"\n            }\n        }\n    }\n    catch {\n        Write-Error \"停止小豆芽失败: $($_.Exception.Message)\"\n    }\n}\n\n# =============================================================================\n# 窗口控制\n# =============================================================================\n\nAdd-Type -AssemblyName System.Windows.Forms\nAdd-Type -AssemblyName System.Drawing\n\nAdd-Type @\"\n    using System;\n    using System.Runtime.InteropServices;\n    \n    public class User32 {\n        [DllImport(\"user32.dll\")]\n        public static extern bool SetForegroundWindow(IntPtr hWnd);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern bool GetWindowRect(IntPtr hWnd, out RECT lpRect);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern bool MoveWindow(IntPtr hWnd, int X, int Y, int nWidth, int nHeight, bool bRepaint);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern IntPtr GetForegroundWindow();\n        \n        [DllImport(\"user32.dll\")]\n        public static extern int GetWindowText(IntPtr hWnd, System.Text.StringBuilder text, int count);\n        \n        [DllImport(\"user32.dll\", SetLastError = true)]\n        public static extern void keybd_event(byte bVk, byte bScan, uint dwFlags, UIntPtr dwExtraInfo);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern bool SetCursorPos(int x, int y);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern void mouse_event(uint dwFlags, uint dx, uint dy, uint dwData, int dwExtraInfo);\n        \n        [DllImport(\"gdi32.dll\")]\n        public static extern bool BitBlt(IntPtr hdcDest, int nXDest, int nYDest, int nWidth, int nHeight, IntPtr hdcSrc, int nXSrc, int nYSrc, int dwRop);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern IntPtr GetDC(IntPtr hWnd);\n        \n        [DllImport(\"user32.dll\")]\n        public static extern int ReleaseDC(IntPtr hWnd, IntPtr hDC);\n        \n        public const int SW_SHOW = 5;\n        public const int SW_HIDE = 0;\n        public const int SW_MINIMIZE = 6;\n        public const int SW_MAXIMIZE = 3;\n        public const int SW_RESTORE = 9;\n        \n        public const uint KEYEVENTF_KEYUP = 0x0002;\n        public const uint MOUSEEVENTF_LEFTDOWN = 0x0002;\n        public const uint MOUSEEVENTF_LEFTUP = 0x0004;\n        \n        public struct RECT {\n            public int Left;\n            public int Top;\n            public int Right;\n            public int Bottom;\n        }\n    }\n\"@\n\nfunction Get-XiaodouyaWindow {\n    [CmdletBinding()]\n    param()\n    \n    Write-XiaodouyaLog \"获取窗口信息...\" -Level \"DEBUG\"\n    \n    try {\n        $processes = Get-XiaodouyaProcess\n        if ($processes.Count -eq 0) {\n            Write-Error \"小豆芽未在运行\"\n            return $null\n        }\n        \n        $windowProcess = $processes | Where-Object { $_.MainWindowHandle -ne [IntPtr]::Zero } | Select-Object -First 1\n        \n        if (-not $windowProcess) {\n            Write-Error \"找不到小豆芽主窗口\"\n            return $null\n        }\n        \n        $hWnd = $windowProcess.MainWindowHandle\n        $rect = New-Object User32+RECT\n        [User32]::GetWindowRect($hWnd, [ref]$rect) | Out-Null\n        \n        $width = $rect.Right - $rect.Left\n        $height = $rect.Bottom - $rect.Top\n        \n        [PSCustomObject]@{\n            ProcessId = $windowProcess.Id\n            Handle = $hWnd\n            Title = $windowProcess.MainWindowTitle\n            Left = $rect.Left\n            Top = $rect.Top\n            Width = $width\n            Height = $height\n            IsForeground = ([User32]::GetForegroundWindow() -eq $hWnd)\n        }\n    }\n    catch {\n        Write-Error \"获取窗口信息失败: $($_.Exception.Message)\"\n        return $null\n    }\n}\n\nfunction Set-XiaodouyaActive {\n    [CmdletBinding()]\n    param()\n    \n    $window = Get-XiaodouyaWindow\n    if (-not $window) { return $false }\n    \n    [User32]::ShowWindow($window.Handle, [User32]::SW_RESTORE) | Out-Null\n    $result = [User32]::SetForegroundWindow($window.Handle)\n    \n    if ($result) {\n        Write-Host \"小豆芽窗口已激活\" -ForegroundColor Green\n    }\n    return $result\n}\n\nfunction Set-XiaodouyaMinimize {\n    [CmdletBinding()]\n    param()\n    \n    $window = Get-XiaodouyaWindow\n    if (-not $window) { return $false }\n    \n    $result = [User32]::ShowWindow($window.Handle, [User32]::SW_MINIMIZE)\n    if ($result) { Write-Host \"小豆芽窗口已最小化\" -ForegroundColor Green }\n    return $result\n}\n\nfunction Set-XiaodouyaMaximize {\n    [CmdletBinding()]\n    param()\n    \n    $window = Get-XiaodouyaWindow\n    if (-not $window) { return $false }\n    \n    $result = [User32]::ShowWindow($window.Handle, [User32]::SW_MAXIMIZE)\n    if ($result) { Write-Host \"小豆芽窗口已最大化\" -ForegroundColor Green }\n    return $result\n}\n\nfunction Move-XiaodouyaWindow {\n    [CmdletBinding()]\n    param(\n        [Parameter(Mandatory = $true)] [int]$X,\n        [Parameter(Mandatory = $true)] [int]$Y,\n        [int]$Width = 0,\n        [int]$Height = 0\n    )\n    \n    $window = Get-XiaodouyaWindow\n    if (-not $window) { return $false }\n    \n    if ($Width -eq 0) { $Width = $window.Width }\n    if ($Height -eq 0) { $Height = $window.Height }\n    \n    $result = [User32]::MoveWindow($window.Handle, $X, $Y, $Width, $Height, $true)\n    if ($result) { Write-Host \"窗口已移动到 ($X, $Y)\" -ForegroundColor Green }\n    return $result\n}\n\n# =============================================================================\n# 截图和高级功能\n# =============================================================================\n\nfunction New-XiaodouyaScreenshot {\n    [CmdletBinding()]\n    param(\n        [string]$Path = \"$env:USERPROFILE\\Documents\\xiaodouya_screenshot_$(Get-Date -Format 'yyyyMMdd_HHmmss').png\"\n    )\n    \n    Write-XiaodouyaLog \"截取屏幕...\" -Level \"DEBUG\"\n    \n    try {\n        $window = Get-XiaodouyaWindow\n        if (-not $window) { return $null }\n        \n        # 确保窗口可见\n        Set-XiaodouyaActive | Out-Null\n        Start-Sleep -Milliseconds 500\n        \n        # 使用System.Drawing截图\n        $bounds = [System.Drawing.Rectangle]::FromLTRB($window.Left, $window.Top, $window.Left + $window.Width, $window.Top + $window.Height)\n        $bitmap = New-Object System.Drawing.Bitmap($bounds.Width, $bounds.Height)\n        $graphics = [System.Drawing.Graphics]::FromImage($bitmap)\n        $graphics.CopyFromScreen($bounds.Location, [System.Drawing.Point]::Empty, $bounds.Size)\n        \n        # 保存截图\n        $directory = Split-Path -Parent $Path\n        if (-not (Test-Path $directory)) {\n            New-Item -ItemType Directory -Path $directory -Force | Out-Null\n        }\n        \n        $bitmap.Save($Path, [System.Drawing.Imaging.ImageFormat]::Png)\n        $graphics.Dispose()\n        $bitmap.Dispose()\n        \n        Write-Host \"截图已保存: $Path\" -ForegroundColor Green\n        Write-XiaodouyaLog \"截图保存成功: $Path\" -Level \"INFO\"\n        \n        return $Path\n    }\n    catch {\n        Write-Error \"截图失败: $($_.Exception.Message)\"\n        Write-XiaodouyaLog \"截图失败: $($_.Exception.Message)\" -Level \"ERROR\"\n        return $null\n    }\n}\n\nfunction Send-XiaodouyaKeys {\n    [CmdletBinding()]\n    param(\n        [Parameter(Mandatory = $true)]\n        [string]$Keys\n    )\n    \n    Write-XiaodouyaLog \"发送按键: $Keys\" -Level \"DEBUG\"\n    \n    try {\n        # 激活窗口\n        Set-XiaodouyaActive | Out-Null\n        Start-Sleep -Milliseconds 200\n        \n        # 使用WScript.Shell发送按键\n        $shell = New-Object -ComObject WScript.Shell\n        $shell.SendKeys($Keys)\n        \n        Write-Host \"已发送按键: $Keys\" -ForegroundColor Green\n        Write-XiaodouyaLog \"按键发送成功\" -Level \"INFO\"\n        return $true\n    }\n    catch {\n        Write-Error \"发送按键失败: $($_.Exception.Message)\"\n        Write-XiaodouyaLog \"按键发送失败: $($_.Exception.Message)\" -Level \"ERROR\"\n        return $false\n    }\n}\n\n# =============================================================================\n# 导出和模块信息\n# =============================================================================\n\n$script:ModuleVersion = \"1.0\"\n\nfunction Get-XiaodouyaModuleInfo {\n    [PSCustomObject]@{\n        Name = \"XiaodouyaAutomation\"\n        Version = $script:ModuleVersion\n        Author = \"OpenClaw\"\n        Description = \"小豆芽自动化控制模块\"\n        Functions = @(\n            \"Get-XiaodouyaProcess\", \"Start-Xiaodouya\", \"Stop-Xiaodouya\",\n            \"Get-XiaodouyaWindow\", \"Set-XiaodouyaActive\", \n            \"Set-XiaodouyaMinimize\", \"Set-XiaodouyaMaximize\",\n            \"Move-XiaodouyaWindow\", \"New-XiaodouyaScreenshot\",\n            \"Send-XiaodouyaKeys\", \"Get-XiaodouyaModuleInfo\"\n        )\n    }\n}\n\n# 导出函数\nExport-ModuleMember -Function Get-XiaodouyaProcess, Start-Xiaodouya, Stop-Xiaodouya,\n    Get-XiaodouyaWindow, Set-XiaodouyaActive, Set-XiaodouyaMinimize, Set-XiaodouyaMaximize,\n    Move-XiaodouyaWindow, New-XiaodouyaScreenshot, Send-XiaodouyaKeys, Get-XiaodouyaModuleInfo\n\nWrite-XiaodouyaLog \"小豆芽自动化模块已加载 (v$script:ModuleVersion)\" -Level \"INFO\"\n"}},{"type":"toolCall","id":"write:10","name":"write","arguments":{"path":"/home/yirongbest/.openclaw/workspace/xiaodouya_aliases.sh","content":"#!/bin/bash\n# =============================================================================\n# 小豆芽 PowerShell 别名脚本\n# 用于从 WSL2 快速控制 Windows 上的小豆芽应用\n# =============================================================================\n\n# PowerShell 路径\nPOWERSHELL=\"/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe\"\n"}},{"type":"thinking","thinking":"\\n","thinkingSignature":"reasoning_content"}],"api":"openai-completions","provider":"volcengine-plan","model":"kimi-k2.5","usage":{"input":21164,"output":8192,"cacheRead":0,"cacheWrite":0,"totalTokens":29356,"cost":{"input":0.0000021164,"output":0.0000016384,"cacheRead":0,"cacheWrite":0,"total":0.0000037548}},"stopReason":"length","timestamp":1772174332388}}
