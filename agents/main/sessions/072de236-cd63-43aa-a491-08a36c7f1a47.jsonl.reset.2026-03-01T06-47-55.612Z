{"type":"message","id":"b1f77a0e","parentId":"aa9d7e1a","timestamp":"2026-02-28T03:54:18.230Z","message":{"role":"toolResult","toolCallId":"read:32","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nimport os\nimport shutil\nimport subprocess\nimport time\nfrom pathlib import Path\nfrom typing import Any, Callable, Dict, List, Optional\n\ntry:\n    import yaml\nexcept ImportError:  # pragma: no cover\n    yaml = None\n\nDEFAULT_APP_PATH = r\"C:\\Program Files\\xiaodouya\\新版小豆芽.exe\"\nDEFAULT_POWERSHELL_EXE = \"/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe\"\nDEFAULT_WIN_PYTHON = r\"C:\\Users\\yuyirong\\AppData\\Local\\Programs\\Python\\Python311\\python.exe\"\nDEFAULT_TIMEOUT_SECONDS = 15\nRETRY_DELAYS = [0.8, 1.6, 3.2]\n\nREQUIRED_SELECTOR_FIELDS = [\n    \"window\",\n    \"entry_xiaohongshu\",\n    \"editor_title\",\n    \"editor_body\",\n    \"tags_input\",\n    \"pre_publish_anchor\",\n    \"confirm_publish_button\",\n]\n\n\nWIN_BRIDGE_SCRIPT = r'''\nimport json\nimport os\nimport re\nimport traceback\nfrom pathlib import Path\n\ndef out(payload):\n    print(json.dumps(payload, ensure_ascii=False))\n\ntry:\n    from pywinauto import Application, Desktop\nexcept Exception as exc:\n    out({\"ok\": False, \"error\": f\"pywinauto import failed: {exc}\"})\n    raise SystemExit(0)\n\npayload = json.loads(os.environ.get(\"XDY_PAYLOAD\", \"{}\"))\n\n[522 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1772250858229}}
{"type":"message","id":"47988d13","parentId":"b1f77a0e","timestamp":"2026-02-28T03:54:18.233Z","message":{"role":"toolResult","toolCallId":"read:33","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport time\nimport uuid\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional\n\ntry:\n    import yaml\nexcept ImportError:  # pragma: no cover\n    yaml = None\n\nfrom controller import XiaodouyaController\n\nDEFAULT_BASE_DIR = Path(__file__).resolve().parent\nDEFAULT_SELECTORS_PATH = DEFAULT_BASE_DIR / \"selectors.yaml\"\nDEFAULT_EVIDENCE_ROOT = DEFAULT_BASE_DIR / \"evidence\"\n\nSTEP_ORDER = [\n    \"attach_or_start\",\n    \"activate\",\n    \"entry_xiaohongshu\",\n    \"editor_title\",\n    \"editor_body\",\n    \"tags_input\",\n    \"pre_publish_anchor\",\n    \"confirm_publish_button\",\n    \"screenshot_prepublish\",\n    \"publish_click\",\n]\n\n\ndef load_content(path: str | Path) -> Dict[str, Any]:\n    content_path = Path(path)\n    if not content_path.exists():\n        raise FileNotFoundError(f\"content file not found: {content_path}\")\n\n    text = content_path.read_text(encoding=\"utf-8\")\n    suffix = content_path.suffix.lower()\n\n    if suffix == \".json\":\n        data = json.loads(text)\n    elif suffix in {\".yaml\", \".yml\"}:\n        if yaml is None:\n            raise RuntimeError(\"PyYAML is required for YAML content file\")\n        data = yaml.safe_load(text)\n    else:\n\n[245 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1772250858232}}
