{"type":"message","id":"2340fe63","parentId":"c853fd15","timestamp":"2026-02-28T03:51:18.919Z","message":{"role":"toolResult","toolCallId":"read:23","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom controller import XiaodouyaController, load_selectors, validate_selectors_schema\nfrom publish_xiaohongshu import (\n    DEFAULT_EVIDENCE_ROOT,\n    DEFAULT_SELECTORS_PATH,\n    STEP_ORDER,\n    run_workflow,\n)\n\ntry:\n    from mcp.server.fastmcp import FastMCP\nexcept ImportError as exc:  # pragma: no cover\n    raise SystemExit(f\"Missing dependency: {exc}. Install with `pip install mcp`.\")\n\n\nmcp = FastMCP(\"xiaodouya-linux-win-control\")\n\n\ndef _selectors_path(selectors_path: Optional[str]) -> Path:\n    return Path(selectors_path) if selectors_path else DEFAULT_SELECTORS_PATH\n\n\ndef _evidence_root(evidence_dir: Optional[str]) -> Path:\n    return Path(evidence_dir) if evidence_dir else DEFAULT_EVIDENCE_ROOT\n\n\ndef _status_from_jsonl(path: Path) -> Dict[str, Any]:\n    if not path.exists():\n        return {\"ok\": False, \"error\": f\"jsonl report not found: {path}\"}\n\n    lines = path.read_text(encoding=\"utf-8\").splitlines()\n    if not lines:\n        return {\"ok\": False, \"error\": \"jsonl report is empty\"}\n\n    last = json.loads(lines[-1])\n    return {\n        \"ok\": True,\n        \"events\": len(lines),\n        \"last_event\": last,\n        \"prepublish_ready\": bool(last.get(\"step\") in {\"screenshot_prepublish\", \"publish_click\"} and last.get(\"ok\")),\n    }\n\n\ndef _controller_for_runtime(selectors_path: Optional[str], evidence_dir: Optional[str]) -> XiaodouyaController:\n\n[131 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1772250678919}}
{"type":"message","id":"918146eb","parentId":"2340fe63","timestamp":"2026-02-28T03:51:18.922Z","message":{"role":"toolResult","toolCallId":"read:24","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nimport os\nimport shutil\nimport subprocess\nimport time\nfrom pathlib import Path\nfrom typing import Any, Callable, Dict, List, Optional\n\ntry:\n    import yaml\nexcept ImportError:  # pragma: no cover\n    yaml = None\n\nDEFAULT_APP_PATH = r\"C:\\Program Files\\xiaodouya\\新版小豆芽.exe\"\nDEFAULT_POWERSHELL_EXE = \"/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe\"\nDEFAULT_WIN_PYTHON = r\"C:\\Users\\yuyirong\\AppData\\Local\\Programs\\Python\\Python311\\python.exe\"\nDEFAULT_TIMEOUT_SECONDS = 15\nRETRY_DELAYS = [0.8, 1.6, 3.2]\n\nREQUIRED_SELECTOR_FIELDS = [\n    \"window\",\n    \"entry_xiaohongshu\",\n    \"editor_title\",\n    \"editor_body\",\n    \"tags_input\",\n    \"pre_publish_anchor\",\n    \"confirm_publish_button\",\n]\n\n\nWIN_BRIDGE_SCRIPT = r'''\nimport json\nimport os\nimport re\nimport traceback\nfrom pathlib import Path\n\ndef out(payload):\n    print(json.dumps(payload, ensure_ascii=False))\n\ntry:\n    from pywinauto import Application, Desktop\nexcept Exception as exc:\n    out({\"ok\": False, \"error\": f\"pywinauto import failed: {exc}\"})\n    raise SystemExit(0)\n\npayload = json.loads(os.environ.get(\"XDY_PAYLOAD\", \"{}\"))\naction = payload.get(\"action\")\nwindow_strategies = payload.get(\"window\") or []\napp_path = payload.get(\"app_path\")\n\n\ndef to_selector_used(kind, raw):\n    return {\"kind\": kind, \"raw\": raw}\n\n\ndef normalize_text(value):\n    try:\n        return str(value or \"\")\n    except Exception:\n        return \"\"\n\n\ndef find_main_window(strategies):\n    desktop = Desktop(backend=\"uia\")\n\n    for strategy in strategies:\n        try:\n            if \"uia\" in strategy:\n                spec = strategy[\"uia\"]\n                kwargs = {}\n                if spec.get(\"title\"):\n                    kwargs[\"title\"] = spec[\"title\"]\n                if spec.get(\"control_type\"):\n                    kwargs[\"control_type\"] = spec[\"control_type\"]\n                if spec.get(\"class_name\"):\n                    kwargs[\"class_name\"] = spec[\"class_name\"]\n                win = desktop.window(**kwargs)\n                wrapper = win.wrapper_object()\n                if wrapper is not None:\n                    return wrapper, to_selector_used(\"uia\", spec)\n\n            if \"title_regex\" in strategy:\n                spec = strategy[\"title_regex\"]\n                pattern = spec.get(\"pattern\", \".*\")\n                reg = re.compile(pattern)\n                expected = normalize_text(spec.get(\"control_type\"))\n                for win in desktop.windows():\n                    name = normalize_text(win.window_text())\n                    if not reg.search(name):\n                        continue\n                    if expected:\n                        actual = normalize_text(getattr(win.element_info, \"control_type\", \"\"))\n                        if actual and actual != expected:\n                            continue\n                    return win.wrapper_object(), to_selector_used(\"title_regex\", spec)\n        except Exception:\n\n[472 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1772250678921}}
