{"type":"message","id":"0256cdc6","parentId":"487d9265","timestamp":"2026-02-28T07:10:27.005Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，现在我可以测试发布帖子了。让我使用 MCP 工具来运行工作流。我将使用 `xdy_run_workflow` 工具来尝试发布测试帖子到小红书。","thinkingSignature":"reasoning_content"},{"type":"text","text":"好的，现在让我使用 MCP 工具测试发布帖子："},{"type":"toolCall","id":"exec:87","name":"exec","arguments":{"command":"source /home/yirongbest/.openclaw/workspace/.venv-xiaodouya/bin/activate && cd /home/yirongbest/.openclaw/workspace/xiaodouya && python << 'PYEOF'\nimport asyncio\nimport json\nimport sys\nimport uuid\nfrom pathlib import Path\n\nsys.path.insert(0, '/home/yirongbest/.openclaw/workspace/xiaodouya')\n\nfrom xiaodouya_mcp_server import mcp\n\nprint(\"=\" * 70)\nprint(\"XIAODOUYA MCP - 测试发布小红书帖子\")\nprint(\"=\" * 70)\n\nasync def test_publish():\n    content_file = \"/home/yirongbest/.openclaw/workspace/xiaodouya/test_content.json\"\n    run_id = f\"mcp_test_{uuid.uuid4().hex[:8]}\"\n    \n    print(f\"\\n📄 Content file: {content_file}\")\n    print(f\"🆔 Run ID: {run_id}\")\n    print(f\"📝 Mode: prepublish (安全预览模式)\")\n    \n    # 读取内容文件显示\n    try:\n        with open(content_file, 'r') as f:\n            content = json.load(f)\n        print(f\"\\n📋 内容预览:\")\n        print(f\"  标题: {content.get('title')}\")\n        print(f\"  正文长度: {len(content.get('body', ''))} 字符\")\n        print(f\"  标签: {', '.join(content.get('tags', []))}\")\n    except Exception as e:\n        print(f\"⚠️ 无法读取内容文件: {e}\")\n    \n    print(\"\\n\" + \"-\" * 70)\n    print(\"🚀 调用 xdy_run_workflow...\")\n    print(\"-\" * 70)\n    \n    try:\n        # 调用工作流\n        result = await mcp.call_tool(\"xdy_run_workflow\", {\n            \"content_file\": content_file,\n            \"mode\": \"prepublish\",  # 使用 prepublish 模式，不会真的发布\n            \"run_id\": run_id,\n            \"evidence_dir\": \"/home/yirongbest/.openclaw/workspace/xiaodouya/evidence\"\n        })\n        \n        print(\"\\n✅ 工作流执行完成!\")\n        print(\"\\n📊 结果:\")\n        \n        # 解析结果\n        if hasattr(result, 'content') and result.content:\n            for item in result.content:\n                if hasattr(item, 'text'):\n                    try:\n                        data = json.loads(item.text)\n                        print(json.dumps(data, indent=2, ensure_ascii=False))\n                    except:\n                        print(item.text[:500])\n        elif isinstance(result, tuple) and len(result) > 0:\n            # 处理 tuple 返回类型\n            content_list = result[0]\n            for item in content_list:\n                if hasattr(item, 'text'):\n                    try:\n                        data = json.loads(item.text)\n                        print(json.dumps(data, indent=2, ensure_ascii=False))\n                    except:\n                        print(item.text[:500])\n        else:\n            print(f\"Raw result: {result}\")\n        \n        # 检查证据目录\n        evidence_dir = Path(f\"/home/yirongbest/.openclaw/workspace/xiaodouya/evidence/{run_id}\")\n        if evidence_dir.exists():\n            print(f\"\\n📁 证据目录已创建: {evidence_dir}\")\n            files = list(evidence_dir.glob(\"*\"))\n            print(f\"   文件数: {len(files)}\")\n            for f in files[:5]:\n                print(f\"   - {f.name}\")\n        \n        print(f\"\\n🆔 Run ID: {run_id}\")\n        print(\"你可以使用这个 run_id 来查询状态或恢复工作流\")\n        \n    except Exception as e:\n        print(f\"\\n❌ 错误: {e}\")\n        import traceback\n        traceback.print_exc()\n\nasync def main():\n    await test_publish()\n    print(\"\\n\" + \"=\" * 70)\n    print(\"测试完成!\")\n    print(\"=\" * 70)\n\nif __name__ == \"__main__\":\n    asyncio.run(main())\nPYEOF","workdir":"/home/yirongbest/.openclaw/workspace"}}],"api":"openai-completions","provider":"volcengine-plan","model":"kimi-k2.5","usage":{"input":56085,"output":1120,"cacheRead":0,"cacheWrite":0,"totalTokens":57205,"cost":{"input":0.000005608500