{"type":"message","id":"35d9d43e","parentId":"8e6fa294","timestamp":"2026-02-27T07:30:40.047Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"read:11","name":"read","arguments":{"path":"/home/yirongbest/.openclaw/workspace/xiaodouya_mcp_server_complete.py","offset":300,"limit":100}},{"type":"toolCall","id":"write:12","name":"write","arguments":{"path":"/home/yirongbest/.openclaw/workspace/xiaodouya_mcp_server_complete.py","content":"#!/usr/bin/env python3\n\"\"\"\n小豆芽 MCP 服务器 - 完整版\n通过 Windows UI Automation API 控制新版小豆芽桌面应用\n\n使用方法:\n1. 添加到 mcp.json: \n   \"xiaodouya\": {\n     \"command\": \"python\",\n     \"args\": [\"/home/yirongbest/.openclaw/workspace/xiaodouya_mcp_server_complete.py\"]\n   }\n\n2. 可用工具:\n   - xiaodouya_discover: 发现所有小豆芽进程\n   - xiaodouya_list_controls: 列出窗口控件\n   - xiaodouya_click: 点击控件或坐标\n   - xiaodouya_input_text: 输入文本\n   - xiaodouya_read_text: 读取控件文本\n   - xiaodouya_screenshot: 截图保存到指定路径\n   - xiaodouya_press_key: 发送按键（如Enter、Tab等）\n   - xiaodouya_scroll: 在窗口中滚动\n   - xiaodouya_get_window_info: 获取窗口位置和大小\n\"\"\"\n\nimport asyncio\nimport json\nimport subprocess\nimport sys\nimport os\nfrom datetime import datetime\nfrom typing import Any, Dict, List, Optional\n\n\nclass XiaodouyaController:\n    \"\"\"小豆芽控制器 - 封装Windows UI Automation操作\"\"\"\n    \n    def __init__(self):\n        self.powershell_path = \"/mnt/c/Windows/System32/windowspowershell/v1.0/powershell.exe\"\n        self.screenshot_dir = \"/home/yirongbest/.openclaw/workspace/screenshots\"\n        os.makedirs(self.screenshot_dir, exist_ok=True)\n    \n    def _run_powershell(self, script: str, timeout: int = 30) -> str:\n        \"\"\"执行PowerShell脚本并返回结果\"\"\"\n        try:\n            result = subprocess.run(\n                [self.powershell_path, \"-Command\", script],\n                capture_output=True,\n                text=True,\n                timeout=timeout\n            )\n            return result.stdout + result.stderr\n        except subprocess.TimeoutExpired:\n            return \"Error: PowerShell command timed out\"\n        except Exception as e:\n            return f\"Error executing PowerShell: {str(e)}\"\n    \n    def discover(self) -> List[Dict[str, Any]]:\n        \"\"\"发现所有小豆芽进程\"\"\"\n        script = '''\n        $results = @()\n        Get-Process | Where-Object { \n            $_.Path -like \"*xiaodouya*\" -or \n            $_.ProcessName -match \"douya|豆芽\" \n        } | ForEach-Object {\n            $results += [PSCustomObject]@{\n                pid = $_.Id\n                name = $_.ProcessName\n                window_title = $_.MainWindowTitle\n                hwnd = $_.MainWindowHandle.ToInt64()\n                path = $_.Path\n            }\n        }\n        $results | ConvertTo-Json -Compress\n        '''\n        result = self._run_powershell(script)\n        try:\n            if result.strip():\n                data = json.loads(result.strip())\n                if isinstance(data, dict):\n                    return [data]\n                return data\n        except json.JSONDecodeError:\n            pass\n        return []\n    \n    def list_controls(self, pid: int) -> Dict[str, Any]:\n        \"\"\"列出指定进程的所有UI控件\"\"\"\n        script = f'''\n        $ErrorActionPreference = \"SilentlyContinue\"\n        try {{\n            Add-Type -AssemblyName UIAutomationClient\n            $process = Get-Process -Id {pid} -ErrorAction Stop\n            $hwnd = $process.MainWindowHandle\n            \n            if ($hwnd -eq 0) {{\n                Write-Output '{{\"error\": \"Process has no main window\"}}'\n                exit\n            }}\n            \n            $ae = [System.Windows.Automation.AutomationElement]::FromHandle($hwnd)\n            $controls = @()\n            \n            function Get-ChildControls($element, $depth=0) {{\n                $children = $element.FindAll([System.Windows.Automation.TreeScope]::Children, [System.Windows.Automation.Condition]::TrueCondition)\n                foreach ($child in $children) {{\n                    $ctrl = @{{\n                        name = $child.Current.Name\n                        control_type = $child.Current.ControlType.ProgrammaticName\n                        automation_id = $child.Current.AutomationId\n                        class_name = $child.Current.ClassName\n                        bounding_rect = @{{\n                            x = $child.Current.BoundingRectangle.X\n                            y = $child.Current.BoundingRectangle.Y\n                            width = $child.Current.BoundingRectangle.Width\n                            height = $child.Current.BoundingRectangle.Height\n                        }}\n                        depth = $depth\n                    }}\n                    $global:controls += $ctrl\n                    if ($depth -lt 2) {{\n                        Get-ChildControls $child ($depth+1)\n                    }}\n                }}\n            }}\n            \n            Get-ChildControls $ae 0\n            $result = @{{\"controls\"=$controls; \"window_title\"=$process.MainWindowTitle; \"hwnd\"=$hwnd.ToInt64()}}\n            $result | ConvertTo-Json -Compress -Depth 10\n        }} catch {{\n            $err = @{{\"error\"=$_.Exception.Message}}\n            $err | ConvertTo-Json -Compress\n        }}\n        '''\n        result = self._run_powershell(script, timeout=60)\n        try:\n            if result.strip():\n                return json.loads(result.strip())\n        except json.JSONDecodeError as e:\n            return {\"error\": f\"Failed to parse result: {str(e)}\", \"raw\": result[:500]}\n        return {\"error\": \"No result from PowerShell\"}\n    \n    def click(self, pid: int, control_name: str = None, x: int = None, y: int = None) -> Dict[str, Any]:\n        \"\"\"点击控件或坐标\"\"\"\n        if x is not None and y is not None:\n            # 直接点击坐标\n            script = f'''\n            Add-Type -AssemblyName System.Windows.Forms\n            [System.Windows.Forms.Cursor]::Position = New-Object System.Drawing.Point({x}, {y})\n            Add-Type @\"\n            using System;\n            using System.Runtime.InteropServices;\n            public class MouseClick {{\n                [DllImport(\"user32.dll\")]\n                public static extern void mouse_event(uint dwFlags, uint dx, uint dy, uint dwData, int dwExtraInfo);\n                public const uint MOUSEEVENTF_LEFTDOWN = 0x02;\n                public const uint MOUSEEVENTF_LEFTUP = 0x04;\n            }}\n\"@\n            [MouseClick]::mouse_event(0x02, 0, 0, 0, 0)\n            [MouseClick]::mouse_event(0x04, 0, 0, 0, 0)\n            Write-Output '{{\"success\": true, \"x\": {x}, \"y\": {y}}}'\n            '''\n        else:\n            # 通过控件名称点击\n            script = f'''\n            $ErrorActionPreference = \"SilentlyContinue\"\n            try {{\n                Add-Type -AssemblyName UIAutomationClient\n                $process = Get-Process -Id {pid}\n                $hwnd = $process.MainWindowHandle\n                $ae = [System.Windows.Automation.AutomationElement]::FromHandle($hwnd)\n                \n                $condition = [System.Windows.Automation.PropertyCondition]::New(\n                    [System.Windows.Automation.AutomationElement]::NameProperty, \"{control_name}\"\n                )\n                $target = $ae.FindFirst([System.Windows.Automation.TreeScope]::Descendants, $condition)\n                \n                if ($target) {{\n                    $pattern = $target.GetCurrentPattern([System.Windows.Automation.PatternIdentifiers]::InvokePattern)\n                    $pattern.Invoke()\n                    Write-Output '{{\"success\": true, \"control\": \"{control_name}\"}}'\n                }} else {{\n                    Write-Output '{{\"error\": \"Control not found: {control_name}\"}}'\n                }}\n            }} catch {{\n                Write-Output '{{\"error\": \"$($_.Exception.Message)\"}}'\n            }}\n            '''\n        result = self._run_powershell(script)\n        try:\n            if result.strip():\n                return json.loads(result.strip())\n        except:\n            return {\"success\": True, \"raw\": result}\n        return {\"error\": \"No result\"}\n    \n    def input_text(self, pid: int, text: str, control_name: str = None) -> Dict[str, Any]:\n        \"\"\"输入文本到控件\"\"\"\n        # 转义特殊字符\n        escaped_text = text.replace('\"', '\\\\\"').replace('$', '\\\\$')\n        script = f'''\n        $ErrorActionPreference = \"SilentlyContinue\"\n        try {{\n            Add-Type -AssemblyName UIAutomationClient\n            $process = Get-Process -Id {pid}\n            $hwnd = $process.MainWindowHandle\n            $ae = [System.Windows.Automation.AutomationElement]::FromHandle($hwnd)\n            \n            $target = $ae\n            if (\"{control_name}\") {{\n                $condition = [System.Windows.Automation.PropertyCondition]::New(\n                    [System.Windows.Automation.AutomationElement]::NameProperty, \"{control_name}\"\n                )\n                $target = $ae.FindFirst([System.Windows.Automation.TreeScope]::Descendants, $condition)\n            }}\n            \n            if ($target) {{\n                $pattern = $target.GetCurrentPattern([System.Windows.Automation.PatternIdentifiers]::ValuePattern)\n                $pattern.SetValue(\"{escaped_text}\")\n                Write-Output '{{\"success\": true, \"text\": \"{escaped_text}\"}}'\n            }} else {{\n                Write-Output '{{\"error\": \"Control not found\"}}'\n            }}\n        }} catch {{\n            Write-Output '{{\"error\": \"$($_.Exception.Message)\"}}'\n        }}\n        '''\n        result = self._run_powershell(script)\n        try:\n            if result.strip():\n                return json.loads(result.strip())\n        except:\n            return {\"success\": True, \"raw\": result}\n        return {\"error\": \"No result\"}\n    \n    def read_text(self, pid: int, control_name: str = None) -> Dict[str, Any]:\n        \"\"\"读取控件文本\"\"\"\n        script = f'''\n        $ErrorActionPreference = \"SilentlyContinue\"\n        try {{\n            Add-Type -AssemblyName UIAutomationClient\n            $process = Get-Process -Id {pid}\n            $hwnd = $process.MainWindowHandle\n            $ae = [System.Windows.Automation.AutomationElement]::FromHandle($hwnd)\n            \n            $target = $ae\n            if (\"{control_name}\") {{\n                $condition = [System.Windows.Automation.PropertyCondition]::New(\n                    [System.Windows.Automation.AutomationElement]::NameProperty, \"{control_name}\"\n                )\n                $target = $ae.FindFirst([System.Windows.Automation.TreeScope]::Descendants, $condition)\n            }}\n            \n            if ($target) {{\n                $text = $target.Current.Name\n                Write-Output '{{\"success\": true, \"text\": \"$text\"}}'\n            }} else {{\n                Write-Output '{{\"error\": \"Control not found\"}}'\n            }}\n        }} catch {{\n            Write-Output '{{\"error\": \"$($_.Exception.Message)\"}}'\n        }}\n        '''\n        result = self._run_powershell(script)\n        try:\n            if result.strip():\n                return json.loads(result.strip())\n        except:\n            return {\"success\": True, \"raw\": result}\n        return {\"error\": \"No result\"}\n    \n    def activate_window(self, pid: int) -> Dict[str, Any]:\n        \"\"\"激活窗口到前台\"\"\"\n        script = f'''\n        Add-Type @\"\n        using System;\n        using System.Runtime.InteropServices;\n        public class WindowHelper {{\n            [DllImport(\"user32.dll\")]\n            public static extern bool SetForegroundWindow(IntPtr hWnd);\n            [DllImport(\"user32.dll\")]\n            public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);\n            public const int SW_RESTORE = 9;\n        }}\n\"@\n        $process = Get-Process -Id {pid}\n        $hwnd = $process.MainWindowHandle\n        [WindowHelper]::ShowWindow($hwnd, [WindowHelper]::SW_RESTORE)\n        [WindowHelper]::SetForegroundWindow($hwnd)\n        Write-Output '{{\"success\": true, \"hwnd\": \"' + $hwnd.ToInt64() + '\"}}'\n        '''\n        result = self._run_powershell(script)\n        try:\n            if result.strip():\n                return json.loads(result.strip())\n        except:\n            return {\"success\": True, \"raw\": result}\n        return {\"error\": \"No result\"}\n\n    # ============ 新增工具方法 ============\n    \n    def screenshot(self, pid: int, save_path: str = None) -> Dict[str, Any]:\n        \"\"\"截图保存到指定路径\"\"\"\n        if save_path is None:\n            timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n            save_path = os.path.join(self.screenshot_dir, f\"xiaodouya_{timestamp}.png\")\n        \n        # 转换WSL路径到Windows路径\n        windows_path = save_path.replace(\"/home/yirongbest/.openclaw/workspace\", \"C:\\\\openclaw_workspace\")\n        windows_path = windows_path.replace(\"/\", \"\\\\\")\n        \n        script = f'''\n        $ErrorActionPreference = \"SilentlyContinue\"\n        try {{\n            Add-Type -AssemblyName System.Windows.Forms\n            Add-Type -AssemblyName System.Drawing\n            \n            $process = Get-Process -Id {pid}\n            $hwnd = $process.MainWindowHandle\n            \n            # 获取窗口位置和大小\n            $rect = New-Object System.Drawing.Rectangle\n            [void][User32]::GetWindowRect($hwnd, [ref]$rect)\n            \n            $width = $rect.Right - $rect.Left\n            $height = $rect.Bottom - $rect.Top\n            \n            # 创建位图\n            $bitmap = New-Object System.Drawing.Bitmap($width, $height)\n            $graphics = [System.Drawing.Graphics]::FromImage($bitmap)\n            \n            # 截图\n            $graphics.CopyFromScreen($rect.Left, $rect.Top, 0, 0, $bitmap.Size)\n            \n            # 保存\n            $bitmap.Save(\"{windows_path}\")\n            $graphics.Dispose()\n            $bitmap.Dispose()\n            \n            Write-Output '{{\"success\": true, \"path\": \"{save_path}\", \"windows_path\": \"{windows_path}\"}}'\n        }} catch {{\n            Write-Output '{{\"error\": \"$($_.Exception.Message)\"}}'\n        }}\n        '''\n        result = self._run_powershell(script, timeout=30)\n        try:\n            if result.strip():\n                return json.loads(result.strip())\n        except:\n            return {\"success\": True, \"path\": save_path, \"raw\": result}\n        return {\"error\": \"No result\"}\n    \n    def press_key(self, pid: int, key: str, modifiers: List[str] = None) -> Dict[str, Any]:\n        \"\"\"发送按键（如Enter、Tab等）\"\"\"\n        # 键名映射\n        key_map = {\n            \"enter\": \"{ENTER}\",\n            \"return\": \"{ENTER}\",\n            \"tab\": \"{TAB}\",\n            \"escape\": \"{ESC}\",\n            \"esc\": \"{ESC}\",\n            \"space\": \" \",\n            \"backspace\": \"{BACKSPACE}\",\n            \"delete\": \"{DELETE}\",\n            \"up\": \"{UP}\",\n            \"down\": \"{DOWN}\",\n            \"left\": \"{LEFT}\",\n            \"right\": \"{RIGHT}\",\n            \"home\": \"{HOME}\",\n            \"end\": \"{END}\",\n            \"pageup\": \"{PGUP}\",\n            \"pagedown\": \"{PGDN}\",\n            \"f1\": \"{F1}\",\n            \"f2\": \"{F2}\",\n            \"f3\": \"{F3}\",\n            \"f4\": \"{F4}\",\n            \"f5\": \"{F5}\",\n            \"f6\": \"{F6}\",\n            \"f7\": \"{F7}\",\n            \"f8\": \"{F8}\",\n            \"f9\": \"{F9}\",\n            \"f10\": \"{F10}\",\n            \"f11\": \"{F11}\",\n            \"f12\": \"{F12}\",\n            \"ctrl\": \"^\",\n            \"alt\": \"%\",\n            \"shift\": \"+\",\n            \"win\": \"#\"\n        }\n        \n        key_lower = key.lower()\n        mapped_key = key_map.get(key_lower, key)\n        \n        # 构建按键序列\n        if modifiers:\n            mod_str = \"\"\n            for"}},{"type":"thinking","thinking":" mod","thinkingSignature":"reasoning_content"}],"api":"openai-completions","provider":"volcengine-plan","model":"kimi-k2.5","usage":{"input":25148,"output":8192,"cacheRead":0,"cacheWrite":0,"totalTokens":33340,"cost":{"input":0.0000025148,"output":0.0000016384,"cacheRead":0,"cacheWrite":0,"total":0.0000041532}},"stopReason":"length","timestamp":1772177170690}}
