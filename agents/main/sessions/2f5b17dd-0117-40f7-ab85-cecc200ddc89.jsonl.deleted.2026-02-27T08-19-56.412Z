{"type":"message","id":"a366a6b6","parentId":"6dd8d048","timestamp":"2026-02-27T07:19:52.406Z","message":{"role":"toolResult","toolCallId":"read:3","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n小豆芽 MCP 服务器\n通过 Windows UI Automation API 控制新版小豆芽桌面应用\n\n使用方法:\n1. 添加到 mcp.json: \n   \"xiaodouya\": {\n     \"command\": \"python\",\n     \"args\": [\"/home/yirongbest/.openclaw/workspace/xiaodouya_mcp_server.py\"]\n   }\n\n2. 可用工具:\n   - xiaodouya_discover: 发现所有小豆芽进程\n   - xiaodouya_list_controls: 列出窗口控件\n   - xiaodouya_click: 点击控件\n   - xiaodouya_input_text: 输入文本\n   - xiaodouya_read_text: 读取控件文本\n\"\"\"\n\nimport asyncio\nimport json\nimport subprocess\nimport sys\nfrom typing import Any, Dict, List, Optional\n\n\nclass XiaodouyaController:\n    \"\"\"小豆芽控制器 - 封装Windows UI Automation操作\"\"\"\n    \n    def __init__(self):\n        self.powershell_path = \"/mnt/c/Windows/System32/windowspowershell/v1.0/powershell.exe\"\n    \n    def _run_powershell(self, script: str) -> str:\n        \"\"\"执行PowerShell脚本并返回结果\"\"\"\n        try:\n            result = subprocess.run(\n                [self.powershell_path, \"-Command\", script],\n                capture_output=True,\n                text=True,\n                timeout=30\n            )\n            return result.stdout + result.stderr\n        except subprocess.TimeoutExpired:\n            return \"Error: PowerShell command timed out\"\n        except Exception as e:\n            return f\"Error executing PowerShell: {str(e)}\"\n    \n    def discover(self) -> List[Dict[str, Any]]:\n        \"\"\"发现所有小豆芽进程\"\"\"\n        script = '''\n        $results = @()\n        Get-Process | Where-Object { \n            $_.Path -like \"*xiaodouya*\" -or \n            $_.ProcessName -match \"douya|С��ѿ|豆芽\" \n        } | ForEach-Object {\n            $results += [PSCustomObject]@{\n                pid = $_.Id\n                name = $_.ProcessName\n                window_title = $_.MainWindowTitle\n                hwnd = $_.MainWindowHandle.ToInt64()\n                path = $_.Path\n            }\n        }\n        $results | ConvertTo-Json -Compress\n        '''\n        result = self._run_powershell(script)\n        try:\n            # 解析JSON结果\n            if result.strip():\n                data = json.loads(result.strip())\n                if isinstance(data, dict):\n                    return [data]\n                return data\n        except json.JSONDecodeError:\n            pass\n        return []\n    \n    def list_controls(self, pid: int) -> Dict[str, Any]:\n        \"\"\"列出指定进程的所有UI控件\"\"\"\n        script = f'''\n        $ErrorActionPreference = \"SilentlyContinue\"\n        try {{\n            Add-Type -AssemblyName UIAutomationClient\n            $ae = [System.Windows.Automation.AutomationElement"}],"isError":false,"timestamp":1772176792399}}
{"type":"message","id":"4b2243ed","parentId":"a366a6b6","timestamp":"2026-02-27T07:23:10.547Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"文件被截断了。让我继续读取文件并使用exec来查看Windows环境。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"read:4","name":"read","arguments":{"path":"/home/yirongbest/.openclaw/workspace/xiaodouya_mcp_server.py","offset":100,"limit":100}},{"type":"toolCall","id":"exec:5","name":"exec","arguments":{"command":"wc -l /home/yirongbest/.openclaw/workspace/xiaodouya_mcp_server.py"}},{"type":"toolCall","id":"write:6","name":"write","arguments":{"path":"/home/yirongbest/.openclaw/workspace/xiaodouya_mcp_server_complete.py","content":"#!/usr/bin/env python3\n\"\"\"\n小豆芽 MCP 服务器 - 完整版\n通过 Windows UI Automation API 控制新版小豆芽桌面应用\n\n使用方法:\n1. 添加到 mcp.json: \n   \"xiaodouya\": {\n     \"command\": \"python\",\n     \"args\": [\"/home/yirongbest/.openclaw/workspace/xiaodouya_mcp_server_complete.py\"]\n   }\n\n2. 可用工具:\n   - xiaodouya_discover: 发现所有小豆芽进程\n   - xiaodouya_list_controls: 列出窗口控件\n   - xiaodouya_click: 点击控件\n   - xiaodouya_input_text: 输入文本\n   - xiaodouya_read_text: 读取控件文本\n   - xiaodouya_screenshot: 截图保存到指定路径\n   - xiaodouya_press_key: 发送按键（如Enter、Tab等）\n   - xiaodouya_scroll: 在窗口中滚动\n   - xiaodouya_get_window_info: 获取窗口位置和大小\n\"\"\"\n\nimport asyncio\nimport json\nimport subprocess\nimport sys\nimport os\nfrom datetime import datetime\nfrom typing import Any, Dict, List, Optional\n\n\nclass XiaodouyaController:\n    \"\"\"小豆芽控制器 - 封装Windows UI Automation操作\"\"\"\n    \n    def __init__(self):\n        self.powershell_path = \"/mnt/c/Windows/System32/windowspowershell/v1.0/powershell.exe\"\n        self.screenshot_dir = \"/home/yirongbest/.openclaw/workspace/screenshots\"\n        os.makedirs(self.screenshot_dir, exist_ok=True)\n    \n    def _run_powershell(self, script: str, timeout: int = 30) -> str:\n        \"\"\"执行PowerShell脚本并返回结果\"\"\"\n        try:\n            result = subprocess.run(\n                [self.powershell_path, \"-Command\", script],\n                capture_output=True,\n                text=True,\n                timeout=timeout\n            )\n            return result.stdout + result.stderr\n        except subprocess.TimeoutExpired:\n            return \"Error: PowerShell command timed out\"\n        except Exception as e:\n            return f\"Error executing PowerShell: {str(e)}\"\n    \n    def discover(self) -> List[Dict[str, Any]]:\n        \"\"\"发现所有小豆芽进程\"\"\"\n        script = '''\n        $results = @()\n        Get-Process | Where-Object { \n            $_.Path -like \"*xiaodouya*\" -or \n            $_.ProcessName -match \"douya|豆芽\" \n        } | ForEach-Object {\n            $results += [PSCustomObject]@{\n                pid = $_.Id\n                name = $_.ProcessName\n                window_title = $_.MainWindowTitle\n                hwnd = $_.MainWindowHandle.ToInt64()\n                path = $_.Path\n            }\n        }\n        $results | ConvertTo-Json -Compress\n        '''\n        result = self._run_powershell(script)\n        try:\n            if result.strip():\n                data = json.loads(result.strip())\n                if isinstance(data, dict):\n                    return [data]\n                return data\n        except json.JSONDecodeError:\n            pass\n        return []\n    \n    def list_controls(self, pid: int) -> Dict[str, Any]:\n        \"\"\"列出指定进程的所有UI控件\"\"\"\n        script = f'''\n        $ErrorActionPreference = \"SilentlyContinue\"\n        try {{\n            Add-Type -AssemblyName UIAutomationClient\n            $process = Get-Process -Id {pid} -ErrorAction Stop\n            $hwnd = $process.MainWindowHandle\n            \n            if ($hwnd -eq 0) {{\n                Write-Output '{{\"error\": \"Process has no main window\"}}'\n                exit\n            }}\n            \n            $ae = [System.Windows.Automation.AutomationElement]::FromHandle($hwnd)\n            $controls = @()\n            \n            function Get-ChildControls($element, $depth=0) {{\n                $children = $element.FindAll([System.Windows.Automation.TreeScope]::Children, [System.Windows.Automation.Condition]::TrueCondition)\n                foreach ($child in $children) {{\n                    $ctrl = @{{\n                        name = $child.Current.Name\n                        control_type = $child.Current.ControlType.ProgrammaticName\n                        automation_id = $child.Current.AutomationId\n                        class_name = $child.Current.ClassName\n                        bounding_rect = @{{\n                            x = $child.Current.BoundingRectangle.X\n                            y = $child.Current.BoundingRectangle.Y\n                            width = $child.Current.BoundingRectangle.Width\n                            height = $child.Current.BoundingRectangle.Height\n                        }}\n                        depth = $depth\n                    }}\n                    $global:controls += $ctrl\n                    if ($depth -lt 2) {{\n                        Get-ChildControls $child ($depth+1)\n                    }}\n                }}\n            }}\n            \n            Get-ChildControls $ae 0\n            $result = @{{\"controls\"=$controls; \"window_title\"=$process.MainWindowTitle; \"hwnd\"=$hwnd.ToInt64()}}\n            $result | ConvertTo-Json -Compress -Depth 10\n        }} catch {{\n            $err = @{{\"error\"=$_.Exception.Message}}\n            $err | ConvertTo-Json -Compress\n        }}\n        '''\n        result = self._run_powershell(script, timeout=60)\n        try:\n            if result.strip():\n                return json.loads(result.strip())\n        except json.JSONDecodeError as e:\n            return {\"error\": f\"Failed to parse result: {str(e)}\", \"raw\": result[:500]}\n        return {\"error\": \"No result from PowerShell\"}\n    \n    def click(self, pid: int, control_name: str = None, x: int = None, y: int = None) -> Dict[str, Any]:\n        \"\"\"点击控件或坐标\"\"\"\n        if x is not None and y is not None:\n            # 直接点击坐标\n            script = f'''\n            Add-Type -AssemblyName System.Windows.Forms\n            [System.Windows.Forms.Cursor]::Position = New-Object System.Drawing.Point({x}, {y})\n            Add-Type @\"\n            using System;\n            using System.Runtime.InteropServices;\n            public class MouseClick {{\n                [DllImport(\"user32.dll\")]\n                public static extern void mouse_event(uint dwFlags, uint dx, uint dy, uint dwData, int dwExtraInfo);\n                public const uint MOUSEEVENTF_LEFTDOWN = 0x02;\n                public const uint MOUSEEVENTF_LEFTUP = 0x04;\n            }}\n\"@\n            [MouseClick]::mouse_event(0x02, 0, 0, 0, 0)\n            [MouseClick]::mouse_event(0x04, 0, 0, 0, 0)\n            Write-Output '{{\"success\": true, \"x\": {x}, \"y\": {y}}}'\n            '''\n        else:\n            # 通过控件名称点击\n            script = f'''\n            $ErrorActionPreference = \"SilentlyContinue\"\n            try {{\n                Add-Type -AssemblyName UIAutomationClient\n                $process = Get-Process -Id {pid}\n                $hwnd = $process.MainWindowHandle\n                $ae = [System.Windows.Automation.AutomationElement]::FromHandle($hwnd)\n                \n                $condition = [System.Windows.Automation.PropertyCondition]::New(\n                    [System.Windows.Automation.AutomationElement]::NameProperty, \"{control_name}\"\n                )\n                $target = $ae.FindFirst([System.Windows.Automation.TreeScope]::Descendants, $condition)\n                \n                if ($target) {{\n                    $pattern = $target.GetCurrentPattern([System.Windows.Automation.PatternIdentifiers]::InvokePattern)\n                    $pattern.Invoke()\n                    Write-Output '{{\"success\": true, \"control\": \"{control_name}\"}}'\n                }} else {{\n                    Write-Output '{{\"error\": \"Control not found: {control_name}\"}}'\n                }}\n            }} catch {{\n                Write-Output '{{\"error\": \"$($_.Exception.Message)\"}}'\n            }}\n            '''\n        result = self._run_powershell(script)\n        try:\n            if result.strip():\n                return json.loads(result.strip())\n        except:\n            return {\"success\": True, \"raw\": result}\n        return {\"error\": \"No result\"}\n    \n    def input_text(self, pid: int, text: str, control_name: str = None) -> Dict[str, Any]:\n        \"\"\"输入文本到控件\"\"\"\n        script = f'''\n        $ErrorActionPreference = \"SilentlyContinue\"\n        try {{\n            Add-Type -AssemblyName UIAutomationClient\n            $process = Get-Process -Id {pid}\n            $hwnd = $process.MainWindowHandle\n            $ae = [System.Windows.Automation.AutomationElement]::FromHandle($hwnd)\n            \n            $target = $ae\n            if (\"{control_name}\") {{\n                $condition = [System.Windows.Automation.PropertyCondition]::New(\n                    [System.Windows.Automation.AutomationElement]::NameProperty, \"{control_name}\"\n                )\n                $target = $ae.FindFirst([System.Windows.Automation.TreeScope]::Descendants, $condition)\n            }}\n            \n            if ($target) {{\n                $pattern = $target.GetCurrentPattern([System.Windows.Automation.PatternIdentifiers]::ValuePattern)\n                $pattern.SetValue(\"{text}\")\n                Write-Output '{{\"success\": true, \"text\": \"{text}\"}}'\n            }} else {{\n                Write-Output '{{\"error\": \"Control not found\"}}'\n            }}\n        }} catch {{\n            Write-Output '{{\"error\": \"$($_.Exception.Message)\"}}'\n        }}\n        '''\n        result = self._run_powershell(script)\n        try:\n            if result.strip():\n                return json.loads(result.strip())\n        except:\n            return {\"success\": True, \"raw\": result}\n        return {\"error\": \"No result\"}\n    \n    def read_text(self, pid: int, control_name: str = None) -> Dict[str, Any]:\n        \"\"\"读取控件文本\"\"\"\n        script = f'''\n        $ErrorActionPreference = \"SilentlyContinue\"\n        try {{\n            Add-Type -AssemblyName UIAutomationClient\n            $process = Get-Process -Id {pid}\n            $hwnd = $process.MainWindowHandle\n            $ae = [System.Windows.Automation.AutomationElement]::FromHandle($hwnd)\n            \n            $target = $ae\n            if (\"{control_name}\") {{\n                $condition = [System.Windows.Automation.PropertyCondition]::New(\n                    [System.Windows.Automation.AutomationElement]::NameProperty, \"{control_name}\"\n                )\n                $target = $ae.FindFirst([System.Windows.Automation.TreeScope]::Descendants, $condition)\n            }}\n            \n            if ($target) {{\n                $text = $target.Current.Name\n                Write-Output '{{\"success\": true, \"text\": \"$text\"}}'\n            }} else {{\n                Write-Output '{{\"error\": \"Control not found\"}}'\n            }}\n        }} catch {{\n            Write-Output '{{\"error\": \"$($_.Exception.Message)\"}}'\n        }}\n        '''\n        result = self._run_powershell(script)\n        try:\n            if result.strip():\n                return json.loads(result.strip())\n        except:\n            return {\"success\": True, \"raw\": result}\n        return {\"error\": \"No result\"}\n    \n    def activate_window(self, pid: int) -> Dict[str, Any]:\n        \"\"\"激活窗口到前台\"\"\"\n        script = f'''\n        Add-Type @\"\n        using System;\n        using System.Runtime.InteropServices;\n        public class WindowHelper {{\n            [DllImport(\"user32.dll\")]\n            public static extern bool SetForegroundWindow(IntPtr hWnd);\n            [DllImport(\"user32.dll\")]\n            public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);\n            public const int SW_RESTORE = 9;\n        }}\n\"@\n        $process = Get-Process -Id {pid}\n        $hwnd = $process.MainWindowHandle\n        [WindowHelper]::ShowWindow($hwnd, [WindowHelper]::SW_RESTORE)\n        [WindowHelper]::SetForegroundWindow($hwnd)\n        Write-Output '{{\"success\": true, \"hwnd\": \"' + $hwnd.ToInt64() + '\"}}'\n        '''\n        result = self._run_powershell(script)\n        try:\n            if result.strip():\n                return json.loads(result.strip())\n        except:\n            return {\"success\": True, \"raw\": result}\n        return {\"error\": \"No result\"}\n\n\n# MCP 服务器处理类\nclass MCPServer:\n    def __init__(self):\n        self.controller = XiaodouyaController()\n    \n    def handle_request(self, request: Dict[str, Any]) -> Dict[str, Any]:\n        \"\"\"处理 MCP 请求\"\"\"\n        method = request.get(\"method\")\n        params = request.get(\"params\", {})\n        \n        if method == \"tools/list\":\n            return self._list_tools()\n        elif method == \"tools/call\":\n            return self._call_tool(params.get(\"name\"), params.get(\"arguments\", {}))\n        elif method == \"initialize\":\n            return {\"result\": {\"protocolVersion\": \"2024-11-05\", \"capabilities\": {}, \"serverInfo\": {\"name\": \"xiaodouya\", \"version\": \"1.0.0\"}}}\n        else:\n            return {\"error\": {\"code\": -32601, \"message\": f\"Unknown method: {method}\"}}\n    \n    def _list_tools(self) -> Dict[str, Any]:\n        \"\"\"列出所有可用工具\"\"\"\n        tools = [\n            {\n                \"name\": \"xiaodouya_discover\",\n                \"description\": \"发现所有小豆芽进程\",\n                \"inputSchema\": {\"type\": \"object\", \"properties\": {}}\n            },\n            {\n                \"name\": \"xiaodouya_list_controls\",\n                \"description\": \"列出窗口控件\",\n                \"inputSchema\": {\"type\": \"object\", \"properties\": {\"pid\": {\"type\": \"integer\", \"description\": \"进程ID\"}}, \"required\": [\"pid\"]}\n            },\n            {\n                \"name\": \"xiaodouya_click\",\n                \"description\": \"点击控件或坐标\",\n                \"inputSchema\": {\"type\": \"object\", \"properties\": {\"pid\": {\"type\": \"integer\"}, \"control_name\": {\"type\": \"string\"}, \"x\": {\"type\": \"integer\"}, \"y\": {\"type\": \"integer\"}}, \"required\": [\"pid\"]}\n            },\n            {\n                \"name\": \"xiaodouya_input_text\",\n                \"description\": \"输入文本到控件\",\n                \"inputSchema\": {\"type\": \"object\", \"properties\": {\"pid\": {\"type\": \"integer\"}, \"text\": {\"type\": \"string\"}, \"control_name\": {\"type\": \"string\"}}, \"required\": [\"pid\", \"text\"]}\n            },\n            {\n                \"name\": \"xiaodouya_read_text\",\n                \"description\": \"读取控件文本\",\n                \"inputSchema\": {\"type\": \"object\", \"properties\": {\"pid\": {\"type\": \"integer\"}, \"control_name\": {\"type\": \"string\"}}, \"required\": [\"pid\"]}\n            },\n            {\n                \"name\": \"xiaodouya_activate_window\",\n                \"description\": \"激活窗口到前台\",\n                \"inputSchema\": {\"type\": \"object\", \"properties\": {\"pid\": {\"type\": \"integer\"}}, \"required\": [\"pid\"]}\n            }\n        ]\n        return {\"result\": {\"tools\": tools}}\n    \n    def _call_tool(self, name: str, arguments: Dict[str, Any]) -> Dict[str, Any]:\n        \"\"\"调用具体工具\"\"\"\n        try:\n            if name == \"xiaodouya_discover\":\n                result = self.controller.discover()\n                return {\"result\": {\"content\": [{\"type\": \"text\", \"text\": json.dumps(result, indent=2, ensure_ascii=False)}]}}\n            elif name == \"xiaodouya_list_controls\":\n                result = self.controller.list_controls(arguments[\"pid\"])\n                return {\"result\": {\"content\": [{\"type\": \"text\", \"text\": json.dumps(result, indent=2, ensure_ascii=False)}]}}\n            elif name == \"xiaodouya_click\":\n                result = self.controller.click(\n                    arguments[\"pid\"],\n                    arguments.get(\"control_name\"),\n                    arguments.get(\"x\"),\n                    arguments.get(\"y\")\n                )\n                return {\"result\": {\"content\": [{\"type\": \"text\", \"text\": json.dumps(result, indent=2, ensure_ascii=False)}]}}\n            elif name == \"xiaodouya_input_text\":\n                result = self.controller.input_text(\n                    arguments[\"pid\"],\n                    arguments[\"text\"],"}},{"type":"thinking","thinking":"n","thinkingSignature":"reasoning_content"}],"api":"openai-completions","provider":"volcengine-plan","model":"kimi-k2.5","usage":{"input":13308,"output":8192,"cacheRead":0,"cacheWrite":0,"totalTokens":21500,"cost":{"input":0.0000013308,"output":0.0000016384,"cacheRead":0,"cacheWrite":0,"total":0.0000029692000000000003}},"stopReason":"length","timestamp":1772176792406}}
