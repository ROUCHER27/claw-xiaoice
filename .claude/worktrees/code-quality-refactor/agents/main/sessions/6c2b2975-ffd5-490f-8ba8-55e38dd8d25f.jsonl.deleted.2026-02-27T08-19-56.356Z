ecent -> /mnt/c/Users/yuyirong/AppData/Roaming/Microsoft/Windows/Recent\ndrwxrwxrwx 1 root root    4096 Feb 26 14:33 Saved Games\ndrwxrwxrwx 1 root root    4096 Feb 26 14:34 Searches\nlrwxrwxrwx 1 root root      62 Feb 26 14:33 SendTo -> /mnt/c/Users/yuyirong/AppData/Roaming/Microsoft/Windows/SendTo\nlrwxrwxrwx 1 root root      65 Feb 26 14:33 Templates -> /mnt/c/Users/yuyirong/AppData/Roaming/Microsoft/Windows/Templates\ndrwxrwxrwx 1 root root    4096 Feb 26 14:39 Videos\n-rwxrwxrwx 1 root root  360448 Feb 26 14:33 ntuser.dat.LOG1\n-rwxrwxrwx 1 root root  561152 Feb 26 14:33 ntuser.dat.LOG2\n-rwxrwxrwx 1 root root      20 Feb 26 14:33 ntuser.ini\n-rwxrwxrwx 1 root root     221 Feb 26 21:11 start_douya.ps1\nlrwxrwxrwx 1 root root      66 Feb 26 14:33 「开始」菜单 -> /mnt/c/Users/yuyirong/AppData/Roaming/Microsoft/Windows/Start Menu"}],"details":{"status":"completed","exitCode":0,"durationMs":411,"aggregated":"total 4036\ndrwxrwxrwx 1 root root    4096 Feb 26 21:11 .\ndrwxrwxrwx 1 root root    4096 Feb 26 14:33 ..\ndrwxrwxrwx 1 root root    4096 Feb 26 14:33 AppData\nlrwxrwxrwx 1 root root      37 Feb 26 14:33 Application Data -> /mnt/c/Users/yuyirong/AppData/Roaming\ndrwxrwxrwx 1 root root    4096 Feb 26 14:33 Contacts\nlrwxrwxrwx 1 root root      65 Feb 26 14:33 Cookies -> /mnt/c/Users/yuyirong/AppData/Local/Microsoft/Windows/INetCookies\ndrwxrwxrwx 1 root root    4096 Feb 27 13:59 Desktop\ndrwxrwxrwx 1 root root    4096 Feb 26 14:33 Documents\ndrwxrwxrwx 1 root root    4096 Feb 27 15:05 Downloads\ndrwxrwxrwx 1 root root    4096 Feb 26 14:33 Favorites\ndrwxrwxrwx 1 root root    4096 Feb 26 14:33 Links\nlrwxrwxrwx 1 root root      35 Feb 26 14:33 Local Settings -> /mnt/c/Users/yuyirong/AppData/Local\ndrwxrwxrwx 1 root root    4096 Feb 26 14:33 Music\nlrwxrwxrwx 1 root root      31 Feb 26 14:33 My Documents -> /mnt/c/Users/yuyirong/Documents\n-rwxrwxrwx 1 root root 2097152 Feb 26 14:54 NTUSER.DAT\n-rwxrwxrwx 1 root root   65536 Feb 26 14:54 NTUSER.DAT{00e7903a-a81c-11f0-8fd0-884560df92e2}.TM.blf\n-rwxrwxrwx 1 root root  524288 Feb 26 14:33 NTUSER.DAT{00e7903a-a81c-11f0-8fd0-884560df92e2}.TMContainer00000000000000000001.regtrans-ms\n-rwxrwxrwx 1 root root  524288 Feb 26 14:33 NTUSER.DAT{00e7903a-a81c-11f0-8fd0-884560df92e2}.TMContainer00000000000000000002.regtrans-ms\nlrwxrwxrwx 1 root root      73 Feb 26 14:33 NetHood -> /mnt/c/Users/yuyirong/AppData/Roaming/Microsoft/Windows/Network Shortcuts\ndrwxrwxrwx 1 root root    4096 Feb 26 14:35 OneDrive\ndrwxrwxrwx 1 root root    4096 Feb 26 16:17 Pictures\nlrwxrwxrwx 1 root root      73 Feb 26 14:33 PrintHood -> /mnt/c/Users/yuyirong/AppData/Roaming/Microsoft/Windows/Printer Shortcuts\nlrwxrwxrwx 1 root root      62 Feb 26 14:33 Recent -> /mnt/c/Users/yuyirong/AppData/Roaming/Microsoft/Windows/Recent\ndrwxrwxrwx 1 root root    4096 Feb 26 14:33 Saved Games\ndrwxrwxrwx 1 root root    4096 Feb 26 14:34 Searches\nlrwxrwxrwx 1 root root      62 Feb 26 14:33 SendTo -> /mnt/c/Users/yuyirong/AppData/Roaming/Microsoft/Windows/SendTo\nlrwxrwxrwx 1 root root      65 Feb 26 14:33 Templates -> /mnt/c/Users/yuyirong/AppData/Roaming/Microsoft/Windows/Templates\ndrwxrwxrwx 1 root root    4096 Feb 26 14:39 Videos\n-rwxrwxrwx 1 root root  360448 Feb 26 14:33 ntuser.dat.LOG1\n-rwxrwxrwx 1 root root  561152 Feb 26 14:33 ntuser.dat.LOG2\n-rwxrwxrwx 1 root root      20 Feb 26 14:33 ntuser.ini\n-rwxrwxrwx 1 root root     221 Feb 26 21:11 start_douya.ps1\nlrwxrwxrwx 1 root root      66 Feb 26 14:33 「开始」菜单 -> /mnt/c/Users/yuyirong/AppData/Roaming/Microsoft/Windows/Start Menu","cwd":"/home/yirongbest/.openclaw/workspace"},"isError":false,"timestamp":1772177323343}}
{"type":"message","id":"53d179b3","parentId":"1dc2994d","timestamp":"2026-02-27T07:28:43.358Z","message":{"role":"toolResult","toolCallId":"read:17","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n小豆芽应用控制器 - 从WSL2控制Windows上的小豆芽应用\n\n使用方法:\n  python xiaodouya_control.py find                    # 查找所有小豆芽进程\n  python xiaodouya_control.py activate 19944              # 激活指定PID的窗口到前台\n  python xiaodouya_control.py minimize 19944            # 最小化窗口\n  python xiaodouya_control.py maximize 19944            # 最大化窗口\n  python xiaodouya_control.py list 19944                # 列出窗口中的所有UI控件\n  python xiaodouya_control.py click 19944 --x 100 --y 200  # 点击指定坐标\n  python xiaodouya_control.py type 19944 --text \"你好\"    # 输入文本\n  python xiaodouya_control.py close 19944               # 关闭应用\n\n参数:\n  --json, -j          输出JSON格式\n  --control, -c       控件名称(用于type命令)\n\n作者: AI Assistant\n日期: 2025-02-27\n\"\"\"\n\nimport argparse\nimport json\nimport subprocess\nimport sys\nimport os\nfrom typing import Any, Dict, List, Optional, Tuple\n\n\nclass XiaodouyaController:\n    \"\"\"小豆芽控制器 - 封装Windows UI Automation操作\"\"\"\n    \n    def __init__(self):\n        self.powershell_path = self._find_powershell()\n    \n    def _find_powershell(self) -> str:\n        \"\"\"查找PowerShell路径\"\"\"\n        candidates = [\n            \"/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe\",\n            \"/mnt/c/Windows/System32/windowspowershell/v1.0/powershell.exe\",\n            \"/mnt/c/Windows/System32/powershell.exe\",\n        ]\n        for path in candidates:\n            if os.path.exists(path):\n                return path\n        try:\n            result = subprocess.run(\n                [\"which\", \"powershell.exe\"],\n                capture_output=True,\n                text=True\n            )\n            if result.returncode == 0:\n                return result.stdout.strip()\n        except:\n            pass\n        return \"/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe\"\n    \n    def _run_powershell(self, script: str, timeout: int = 30) -> Tuple[bool, str]:\n        \"\"\"执行PowerShell脚本并返回结果\"\"\"\n        try:\n            wrapped_script = f'''\n$ErrorActionPreference = \"Stop\"\ntry {{\n    $OutputEncoding = [Console]::OutputEncoding = [System.Text.Encoding]::UTF8\n    {script}\n}} catch {{\n    \"ERROR: $_\" | Write-Output\n    exit 1\n}}\n'''\n            \n            result = subprocess.run(\n                [self.powershell_path, \"-NoProfile\", \"-ExecutionPolicy\", \"Bypass\", \"-Command\", wrapped_script],\n                capture_output=True,\n                timeout=timeout\n            )\n            \n            stdout = \"\"\n            stderr = \"\"\n            for encoding in ['utf-8', 'gbk', 'gb2312', 'cp936']:\n                try:\n                    stdout = result.stdout.decode(encoding, errors='replace')\n                    stderr = result.stderr.decode(encoding, errors='replace')\n                    break\n                except:\n                    continue\n            \n            if result.returncode != 0:\n                return False, f\"PowerShell error (code {result.returncode}): {stderr}\\n{stdout}\"\n            \n            return True, stdout + stderr\n            \n        except subprocess.TimeoutExpired:\n            return False, \"ERROR: PowerShell command timed out\"\n        except Exception as e:\n            return False, f\"ERROR executing PowerShell: {str(e)}\"\n    \n    def _output(self, data: Any, success: bool = True, json_output: bool = False):\n        \"\"\"输出结果\"\"\"\n        if json_output:\n            output = {\n                \"success\": success,\n                \"data\": data if success else None,\n                \"error\": str(data) if not success else None\n            }\n            print(json.dumps(output, ensure_ascii=False, indent=2))\n        else:\n            if success:\n                if isinstance(data, (list, dict)):\n                    print(json.dumps(data, ensure_ascii=False, indent=2))\n                else:\n                    print(data)\n            else:\n                print(f\"Error: {data}\", file=sys.stderr)\n                sys.exit(1)\n\n    def find(self, json_output: bool = False) -> List[Dict[str, Any]]:\n        \"\"\"查找所有小豆芽进程\"\"\"\n        script = '''\n$results = @()\nGet-Process | Where-Object { \n    $_.Path -like \"*xiaodouya*\" -or \n    $_.Path -like \"*新版小豆芽*\" -or\n    $_.ProcessName -match \"douya|豆芽\"\n} | ForEach-Object {\n    $hwnd = $_.MainWindowHandle.ToInt64()\n    $results += [PSCustomObject]@{\n        pid = $_.Id\n        name = $_.ProcessName\n        window_title = $_.MainWindowTitle\n        hwnd = $hwnd\n        has_window = ($hwnd -ne 0)\n        path = $_.Path\n    }\n}\nif ($results.Count -eq 0) { $results = @() }\n$results | ConvertTo-Json -Compress -AsArray\n'''\n        \n        success, output = self._run_powershell(script)\n        if not success:\n            self._output(f\"Failed to find processes: {output}\", success=False, json_output=json_output)\n            return []\n        \n        try:\n            start = output.find('[')\n            end = output.rfind(']') + 1\n            if start >= 0 and end > start:\n                data = json.loads(output[start:end])\n            else:\n                start = output.find('{')\n                if start >= 0:\n                    data = json.loads(output[start:])\n                    data = [data] if isinstance(data, dict) else data\n                else:\n                    data = []\n            \n            self._output(data, success=True, json_output=json_output)\n            return data\n        except Exception as e:\n            self._output(f\"Parse error: {e}, raw: {output[:500]}\", success=False, json_output=json_output)\n            return []\n\n    def activate(self, pid: int, json_output: bool = False) -> bool:\n        \"\"\"激活指定PID的窗口到前台\"\"\"\n        script = f'''\nAdd-Type @\"\nusing System;\nusing System.Runtime.InteropServices;\npublic class Win32 {{\n    [DllImport(\"user32.dll\")]\n    public static extern bool SetForegroundWindow(IntPtr hWnd);\n    [DllImport(\"user32.dll\")]\n    public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);\n    [DllImport(\"user32.dll\")]\n    public static extern bool IsIconic(IntPtr hWnd);\n    [DllImport(\"user32.dll\")]\n    public static extern uint GetWindowThreadProcessId(IntPtr hWnd, out uint lpdwProcessId);\n    [DllImport(\"user32.dll\")]\n    public static extern bool EnumWindows(EnumWindowsProc enumProc, IntPtr lParam);\n    [DllImport(\"user32.dll\")]\n    public static extern bool IsWindowVisible(IntPtr hWnd);\n    [DllImport(\"user32.dll\")]\n    public static extern bool AttachThreadInput(uint idAttach, uint idAttachTo, bool fAttach);\n    [DllImport(\"user32.dll\", SetLastError = true)]\n    public static extern uint GetWindowThreadId(IntPtr hWnd);\n    public delegate bool EnumWindowsProc(IntPtr hWnd, IntPtr lParam);\n    \n    public const int SW_RESTORE = 9;\n    public const int SW_SHOW = 5;\n    \n    public static IntPtr FindWindowByPid(int pid) {{\n        IntPtr result = IntPtr.Zero;\n        EnumWindows((hWnd, lParam) => {{\n            uint wPid = 0;\n            GetWindowThreadProcessId(hWnd, out wPid);\n            if ((int)wPid == pid) {{\n                if (IsWindowVisible(hWnd) || result == IntPtr.Zero) {{\n                    result = hWnd;\n                    if (IsWindowVisible(hWnd)) return false;\n                }}\n            }}\n            return true;\n        }}, IntPtr.Zero);\n        return result;\n    }}\n}}\n\"@\n\n$process = Get-Process -Id {pid} -ErrorAction SilentlyContinue\nif (-not $process) {{\n    Write-Error \"Process with PID {pid} not found\"\n    exit 1\n}}\n\n$hwnd = $process.MainWindowHandle\nif ($hwnd -eq [IntPtr]::Zero) {{\n    $hwnd = [Win32]::FindWindowByPid({pid})\n}}\n\nif ($hwnd -eq [IntPtr]::Zero) {{\n    Write-Error \"Could not find window for PID {pid}\"\n    exit 1\n}}\n\n# Force foreground window with proper thread attachment\n$foregroundHwnd = [Win32]::GetForegroundWindow()\n$foregroundThread = [Win32]::GetWindowThreadId($foregroundHwnd)\n$targetThread = [Win32]::GetWindowThreadId($hwnd)\n\nif ($foregroundThread -ne $targetThread) {{\n    [void][Win32]::AttachThreadInput($foregroundThread, $targetThread, $true)\n}}\n\nif ([Win32]::IsIconic($hwnd)) {{\n    [Win32]::ShowWindow($hwnd, [Win32]::SW_RESTORE)\n}}\n\n$result = [Win32]::SetForegroundWindow($hwnd)\n[Win32]::ShowWindow($hwnd, [Win32]::SW_SHOW)\n\nif ($foregroundThread -ne $targetThread) {{\n    [void][Win32]::AttachThreadInput($foregroundThread, $targetThread, $false)\n}}\n\nif ($result) {{\n    Write-Output '{{\"success\": true, \"message\": \"Window activated successfully\", \"hwnd\": \"' + $hwnd.ToString() + '\"}}'\n}} else {{\n    Write-Warning \"SetForegroundWindow returned false, but window may still be activated\"\n    Write-Output '{{\"success\": true, \"message\": \"Window activation attempted\", \"hwnd\": \"' + $hwnd.ToString() + '\"}}'\n}}\n'''\n        \n        success, output = self._run_powershell(script)\n        if not success:\n            self._output(f\"Failed to activate window: {output}\", success=False, json_output=json_output)\n            return False\n        \n        try:\n            json_start = output.find('{')\n            json_end = output.rfind('}') + 1\n            if json_start >= 0 and json_end > json_start:\n                result = json.loads(output[json_start:json_end])\n                success = result.get(\"success\", False)\n                self._output(result if success else result.get(\"message\", \"Unknown error\"), \n                            success=success, json_output=json_output)\n                return success\n            else:\n                raise ValueError(\"No JSON found in output\")\n        except Exception as e:\n            self._output(f\"Parse error: {e}, raw: {output[:500]}\", success=False, json_output=json_output)\n            return False\n    \n    def minimize(self, pid: int, json_output: bool = False) -> bool:\n        \"\"\"最小化窗口\"\"\"\n        return self._show_window(pid, 6, \"minimized\", json_output)\n    \n    def maximize(self, pid: int, json_output: bool = False) -> bool:\n        \"\"\"最大化窗口\"\"\"\n        return self._show_window(pid, 3, \"maximized\", json_output)\n    \n    def _show_window(self, pid: int, cmd: int, state_name: str, json_output: bool) -> bool:\n        \"\"\"执行窗口显示命令\"\"\"\n        script = f'''\nAdd-Type @\"\nusing System;\nusing System.Runtime.InteropServices;\npublic class WindowController {{\n    [DllImport(\"user32.dll\")]\n    public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);\n    [DllImport(\"user32.dll\")]\n    public static extern uint GetWindowThreadProcessId(IntPtr hWnd, out uint lpdwProcessId);\n    [DllImport(\"user32.dll\")]\n    public static extern bool EnumWindows(EnumWindowsProc enumProc, IntPtr lParam);\n    [DllImport(\"user32.dll\")]\n    public static extern bool IsWindowVisible(IntPtr hWnd);\n    public delegate bool EnumWindowsProc(IntPtr hWnd, IntPtr lParam);\n    public static IntPtr FindWindowByPid(int pid) {{\n        IntPtr result = IntPtr.Zero;\n        EnumWindows((hWnd, lParam) => {{\n            uint wPid = 0;\n            GetWindowThreadProcessId(hWnd, out wPid);\n            if ((int)wPid == pid) {{\n                if (IsWindowVisible(hWnd) || result == IntPtr.Zero) {{\n                    result = hWnd;\n                    if (IsWindowVisible(hWnd)) return false;\n                }}\n            }}\n            return true;\n        }}, IntPtr.Zero);\n        return result;\n    }}\n}}\n\"@\n$process = Get-Process -Id {pid} -ErrorAction SilentlyContinue\nif (-not $process) {{\n    Write-Error \"Process with PID {pid} not found\"\n    exit 1\n}}\n$hwnd = $process.MainWindowHandle\nif ($hwnd -eq [IntPtr]::Zero) {{\n    $hwnd = [WindowController]::FindWindowByPid({pid})\n}}\nif ($hwnd -eq [IntPtr]::Zero) {{\n    Write-Error \"Could not find window for PID {pid}\"\n    exit 1\n}}\n$result = [WindowController]::ShowWindow($hwnd, {cmd})\nWrite-Output (ConvertTo-Json -Compress @{{success=$true; state=\"{state_name}\"; result=$result}})\n'''\n        success, output = self._run_powershell(script)\n        if not success:\n            self._output(f\"Failed to change window state: {output}\", success=False, json_output=json_output)\n            return False\n        try:\n            json_start = output.find('{')\n            json_end = output.rfind('}') + 1\n            if json_start >= 0 and json_end > json_start:\n                result = json.loads(output[json_start:json_end])\n                success = result.get(\"success\", False)\n                self._output(result if success else result, success=success, json_output=json_output)\n                return success\n            else:\n                raise ValueError(\"No JSON found in output\")\n        except Exception as e:\n            self._output(f\"Parse error: {e}, raw: {output[:500]}\", success=False, json_output=json_output)\n            return False\n\n    def list_controls(self, pid: int, json_output: bool = False) -> List[Dict[str, Any]]:\n        \"\"\"列出窗口中的所有UI控件\"\"\"\n        script = f\"\"\"\nAdd-Type -AssemblyName UIAutomationClient\n\n$process = Get-Process -Id {pid} -ErrorAction SilentlyContinue\nif (-not $process) {{\n    Write-Error \"Process not found\"\n    exit 1\n}}\n\n$hwnd = $process.MainWindowHandle\nif ($hwnd -eq 0) {{\n    Write-Error \"No main window\"\n    exit 1\n}}\n\ntry {{\n    $elem = [System.Windows.Automation.AutomationElement]::FromHandle($hwnd)\n    $all = $elem.FindAll([System.Windows.Automation.TreeScope]::Descendants, [System.Windows.Automation.Condition]::TrueCondition)\n    \n    $controls = @()\n    for ($i = 0; $i -lt $all.Count -and $i -lt 100; $i++) {{\n        $c = $all[$i]\n        try {{\n            $rect = $c.Current.BoundingRectangle\n            if ($rect.Width -gt 0 -and $rect.Height -gt 0) {{\n                $pat = \"\"\n                if ($c.TryGetCurrentPattern([System.Windows.Automation.PatternIdentifiers]::InvokePattern, [ref]$pat)) {{ $pat = \"Invoke\" }}\n                elseif ($c.TryGetCurrentPattern([System.Windows.Automation.PatternIdentifiers]::ValuePattern, [ref]$pat)) {{ $pat = \"Value\" }}\n                \n                $controls += @{{\n                    name = $c.Current.Name\n                    class = $c.Current.ClassName\n                    type = $c.Current.ControlType.ProgrammaticName\n                    x = [int]$rect.X\n                    y = [int]$rect.Y\n                    width = [int]$rect.Width\n                    height = [int]$rect.Height\n                    pattern = $pat\n                }}\n            }}\n        }} catch {{ }}\n    }}\n    \n    ConvertTo-Json -Compress @{{success=$true; count=$controls.Count; controls=$controls}}\n}} catch {{\n    Write-Error \"UIA Error: $_\"\n    exit 1\n}}\n\"\"\"\n        success, output = self._run_powershell(script)\n        if not success:\n            self._output(f\"Failed to list controls: {output}\", success=False, json_output=json_output)\n            return []\n        try:\n            json_start = output.find('{')\n            json_end = output.rfind('}') + 1\n            if json_start >="}],"isError":false,"timestamp":1772177323352}}
