{"type":"message","id":"6698d01b","parentId":"69ce166f","timestamp":"2026-02-27T06:34:39.008Z","message":{"role":"toolResult","toolCallId":"read:4","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n小豆芽控制脚本 - 从WSL2控制Windows上的小豆芽应用\n\n使用方法:\n  python xiaodouya_control.py find          # 查找进程\n  python xiaodouya_control.py activate 19944 # 激活窗口\n  python xiaodouya_control.py list 19944     # 列出控件\n  python xiaodouya_control.py click 19944 --x 100 --y 200  # 点击坐标\n  python xiaodouya_control.py type 19944 --text \"你好\"       # 输入文本\n\n作者: AI Assistant\n日期: 2025-02-27\n\"\"\"\n\nimport argparse\nimport json\nimport subprocess\nimport sys\nfrom typing import Any, Dict, List, Optional\n\n\nclass XiaodouyaController:\n    \"\"\"小豆芽控制器 - 封装Windows UI Automation操作\"\"\"\n    \n    def __init__(self):\n        self.powershell_path = \"/mnt/c/Windows/System32/windowspowershell/v1.0/powershell.exe\"\n    \n    def _run_powershell(self, script: str, timeout: int = 30) -> str:\n        \"\"\"执行PowerShell脚本并返回结果\"\"\"\n        try:\n            # 添加错误处理和输出编码\n            wrapped_script = f'''\n            $ErrorActionPreference = \"Continue\"\n            $OutputEncoding = [Console]::OutputEncoding = [System.Text.Encoding]::UTF8\n            try {{\n                {script}\n            }} catch {{\n                \"ERROR: $_\"\n            }}\n            '''\n            \n            result = subprocess.run(\n                [self.powershell_path, \"-Command\", wrapped_script],\n                capture_output=True,\n                timeout=timeout\n            )\n            \n            # 尝试多种编码解码\n            for encoding in ['utf-8', 'gbk', 'gb2312', 'cp936']:\n                try:\n                    stdout = result.stdout.decode(encoding, errors='replace')\n                    stderr = result.stderr.decode(encoding, errors='replace')\n                    return stdout + stderr\n                except:\n                    continue\n            \n            return result.stdout.decode('utf-8', errors='ignore') + result.stderr.decode('utf-8', errors='ignore')\n            \n        except subprocess.TimeoutExpired:\n            return \"ERROR: PowerShell command timed out\"\n        except Exception as e:\n            return f\"ERROR executing PowerShell: {str(e)}\"\n    \n    def find_processes(self) -> List[Dict[str, Any]]:\n        \"\"\"查找所有小豆芽进程\"\"\"\n        script = '''\n        $results = @()\n        Get-Process | Where-Object { \n            $_.Path -like \"*xiaodouya*\" -or \n            $_.Path -like \"*С��ѿ*\" -or\n            $_.ProcessName -match \"douya|С��ѿ|豆芽\" \n        } | ForEach-Object {\n            $hwnd = $_.MainWindowHandle.ToInt64()\n            $results += [PSCustomObject]@{\n                pid = $_.Id\n                name = $_.ProcessName\n                window_title = $_.MainWindowTitle\n                hwnd = $hwnd\n                has_window = ($hwnd -ne 0)\n                path = $_.Path\n            }\n        }\n        $results | ConvertTo-Json -Compress -AsArray\n        '''\n        result = self._run_powershell(script)\n        try:\n            # 提取JSON部分\n            start = result.find('[')\n            end = result.rfind(']') + 1\n            if start >= 0 and end > start:\n                return json.loads(result[start:end])\n            # 可能是单个对象\n            start = result.find('{')\n            end = result.rfind('}') + 1\n            if start >= 0 and end > start:\n                data = json.loads(result[start:end])\n                return [data] if isinstance(data, dict) else data\n        except Exception as e:\n            print(f\"Parse error: {e}, raw result: {result[:500]}\", file=sys.stderr)\n\n[208 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1772174079004}}
