{"type":"message","id":"091108ab","parentId":"e579a5f5","timestamp":"2026-02-28T05:48:14.320Z","message":{"role":"toolResult","toolCallId":"read:14","toolName":"read","content":[{"type":"text","text":"window:\n  - process_id:\n      id: 19944\n  - title_regex:\n      pattern: \".*\"\n\nentry_xiaohongshu:\n  - uia:\n      title: \"е°Ҹзәўд№Ұ\"\n      control_type: \"Button\"\n  - title_regex:\n      pattern: \".*е°Ҹзәўд№Ұ.*\"\n      control_type: \"Button\"\n  - image_key:\n      key: \"entry_xiaohongshu\"\n      threshold: 0.90\n\neditor_title:\n  - uia:\n      auto_id: \"title\"\n      control_type: \"Edit\"\n  - title_regex:\n      pattern: \".*(ж Үйўҳ|title).*\"\n      control_type: \"Edit\"\n  - image_key:\n      key: \"editor_title\"\n      threshold: 0.90\n\neditor_body:\n  - uia:\n      auto_id: \"content\"\n      control_type: \"Edit\"\n  - title_regex:\n      pattern: \".*(жӯЈж–Ү|еҶ…е®№|content).*\"\n      control_type: \"Edit\"\n  - image_key:\n      key: \"editor_body\"\n      threshold: 0.88\n\ntags_input:\n  - uia:\n      auto_id: \"tags\"\n      control_type: \"Edit\"\n  - title_regex:\n      pattern: \".*(ж Үзӯҫ|иҜқйўҳ|tag).*\"\n      control_type: \"Edit\"\n  - image_key:\n      key: \"tags_input\"\n      threshold: 0.88\n\npre_publish_anchor:\n  - uia:\n      title: \"еҸ‘еёғ\"\n      control_type: \"Button\"\n  - title_regex:\n      pattern: \".*(йў„и§Ҳ|еҸ‘еёғ|publish).*\"\n      control_type: \"Button\"\n  - image_key:\n      key: \"pre_publish_anchor\"\n      threshold: 0.86\n\nconfirm_publish_button:\n  - uia:\n      title: \"еҸ‘еёғ\"\n      control_type: \"Button\"\n  - title_regex:\n      pattern: \"^(еҸ‘еёғ|з«ӢеҚіеҸ‘еёғ|publish)$\"\n      control_type: \"Button\"\n  - image_key:\n      key: \"confirm_publish_button\"\n      threshold: 0.90\n"}],"isError":false,"timestamp":1772257694318}}
{"type":"message","id":"ddd552a8","parentId":"091108ab","timestamp":"2026-02-28T05:48:14.323Z","message":{"role":"toolResult","toolCallId":"read:15","toolName":"read","content":[{"type":"text","text":"{\n  \"title\": \"дҪ еҘҪпјҢе°Ҹзәўд№Ұ\",\n  \"body\": \"иҝҷжҳҜйҖҡиҝҮ OpenClaw Linux->Windows иҮӘеҠЁеҢ–жөҒзЁӢз”ҹжҲҗзҡ„жөӢиҜ•ж–ҮжЎҲгҖӮ\",\n  \"tags\": [\"#иҮӘеҠЁеҢ–\", \"#жөӢиҜ•\"]\n}\n"}],"isError":false,"timestamp":1772257694322}}
{"type":"message","id":"45bf164a","parentId":"ddd552a8","timestamp":"2026-02-28T05:48:14.326Z","message":{"role":"toolResult","toolCallId":"read:16","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport json\nfrom pathlib import Path\nfrom typing import Any, Dict, Optional\n\nfrom controller import XiaodouyaController, load_selectors, validate_selectors_schema\nfrom publish_xiaohongshu import (\n    DEFAULT_EVIDENCE_ROOT,\n    DEFAULT_SELECTORS_PATH,\n    STEP_ORDER,\n    run_workflow,\n)\n\ntry:\n    from mcp.server.fastmcp import FastMCP\nexcept ImportError as exc:  # pragma: no cover\n    raise SystemExit(f\"Missing dependency: {exc}. Install with `pip install mcp`.\")\n\n\nmcp = FastMCP(\"xiaodouya-linux-win-control\")\n\n\ndef _selectors_path(selectors_path: Optional[str]) -> Path:\n    return Path(selectors_path) if selectors_path else DEFAULT_SELECTORS_PATH\n\n\ndef _evidence_root(evidence_dir: Optional[str]) -> Path:\n    return Path(evidence_dir) if evidence_dir else DEFAULT_EVIDENCE_ROOT\n\n\ndef _status_from_jsonl(path: Path) -> Dict[str, Any]:\n    if not path.exists():\n        return {\"ok\": False, \"error\": f\"jsonl report not found: {path}\"}\n\n    lines = path.read_text(encoding=\"utf-8\").splitlines()\n    if not lines:\n        return {\"ok\": False, \"error\": \"jsonl report is empty\"}\n\n    last = json.loads(lines[-1])\n    return {\n        \"ok\": True,\n        \"events\": len(lines),\n        \"last_event\": last,\n        \"prepublish_ready\": bool(last.get(\"step\") in {\"screenshot_prepublish\", \"publish_click\"} and last.get(\"ok\")),\n    }\n\n\ndef _controller_for_runtime(selectors_path: Optional[str], evidence_dir: Optional[str]) -> XiaodouyaController:\n    return XiaodouyaController(\n        selectors_path=_selectors_path(selectors_path),\n        evidence_dir=_evidence_root(evidence_dir),\n    )\n\n\n@mcp.tool()\ndef xdy_run_workflow(\n    content_file: str,\n    mode: str = \"prepublish\",\n    resume_from: Optional[str] = None,\n    evidence_dir: Optional[str] = None,\n    run_id: Optional[str] = None,\n    selectors_path: Optional[str] = None,\n) -> Dict[str, Any]:\n    \"\"\"Run full workflow: attach/start -> fill content -> prepublish/publish.\"\"\"\n    return run_workflow(\n        content_file=content_file,\n        mode=mode,\n        resume_from=resume_from,\n        evidence_dir=evidence_dir,\n        run_id=run_id,\n        selectors_path=selectors_path,\n    )\n\n\n@mcp.tool()\ndef xdy_step(\n    step: str,\n    action: str = \"wait_for\",\n    text: str = \"\",\n    selectors_path: Optional[str] = None,\n    evidence_dir: Optional[str] = None,\n) -> Dict[str, Any]:\n    \"\"\"Execute one step action: wait_for/click/type_text/screenshot/activate/attach_or_start.\"\"\"\n    controller = _controller_for_runtime(selectors_path, evidence_dir)\n\n    if action == \"attach_or_start\":\n        return controller.attach_or_start()\n    if action == \"activate\":\n        return controller.activate()\n    if action == \"wait_for\":\n        return controller.wait_for(step)\n    if action == \"click\":\n        return controller.click(step)\n    if action == \"type_text\":\n        return controller.type_text(step, text)\n    if action == \"screenshot\":\n        return controller.screenshot(step)\n\n    return {\"ok\": False, \"error\": f\"unsupported action: {action}\"}\n\n\n@mcp.tool()\ndef xdy_resume(\n    run_id: str,\n    content_file: str,\n    mode: str = \"prepublish\",\n    resume_from: Optional[str] = None,\n    evidence_dir: Optional[str] = None,\n    selectors_path: Optional[str] = None,\n) -> Dict[str, Any]:\n    \"\"\"Resume workflow from explicit step or auto-detected failed step from jsonl.\"\"\"\n    root = _evidence_root(evidence_dir)\n    run_dir = root / run_id\n    jsonl_path = run_dir / f\"run_report_{run_id}.jsonl\"\n\n    start_step = resume_from\n    if start_step is None and jsonl_path.exists():\n        events = [json.loads(line) for line in jsonl_path.read_text(encoding=\"utf-8\").splitlines() if line.strip()]\n        failed = [e for e in events if not e.get(\"ok\")]\n        if failed:\n            start_step = failed[-1][\"step\"]\n\n    if start_step is None:\n        start_step = STEP_ORDER[0]\n\n    return run_workflow(\n        content_file=content_file,\n        mode=mode,\n        resume_from=start_step,\n        evidence_dir=str(root),\n        run_id=run_id,\n        selectors_path=selectors_path,\n    )\n\n\n@mcp.tool()\ndef xdy_get_status(run_id: str, evidence_dir: Optional[str] = None) -> Dict[str, Any]:\n    \"\"\"Get run status by reading run_report_<id>.jsonl/md.\"\"\"\n    root = _evidence_root(evidence_dir)\n    run_dir = root / run_id\n    jsonl_path = run_dir / f\"run_report_{run_id}.jsonl\"\n    md_path = run_dir / f\"run_report_{run_id}.md\"\n\n    status = _status_from_jsonl(jsonl_path)\n    status.update(\n        {\n            \"run_id\": run_id,\n            \"report_jsonl\": str(jsonl_path),\n            \"report_md\": str(md_path),\n            \"report_md_exists\": md_path.exists(),\n        }\n    )\n    return status\n\n\n@mcp.tool()\ndef xdy_list_selectors(selectors_path: Optional[str] = None) -> Dict[str, Any]:\n    \"\"\"List current selectors map.\"\"\"\n    path = _selectors_path(selectors_path)\n    selectors = load_selectors(path)\n    return {\"ok\": True, \"selectors_path\": str(path), \"selectors\": selectors}\n\n\n@mcp.tool()\ndef xdy_validate_selectors(selectors_path: Optional[str] = None) -> Dict[str, Any]:\n    \"\"\"Validate selector schema and minimum strategy count.\"\"\"\n    path = _selectors_path(selectors_path)\n    selectors = load_selectors(path)\n    errors = validate_selectors_schema(selectors)\n    return {\n        \"ok\": len(errors) == 0,\n        \"selectors_path\": str(path),\n        \"errors\": errors,\n    }\n\n\nif __name__ == \"__main__\":\n    mcp.run()\n"}],"isError":false,"timestamp":1772257694325}}
{"type":"message","id":"4007435e","parentId":"45bf164a","timestamp":"2026-02-28T05:48:32.057Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"и®©жҲ‘з»§з»ӯжҹҘзңӢе…¶д»–зӣёе…іж–Үд»¶пјҢзЎ®и®ӨжҳҜеҗҰеҸҜд»ҘејҖе§ӢжөӢиҜ•гҖӮжҲ‘йңҖиҰҒжЈҖжҹҘпјҡ\n\n1. controller.py зҡ„е…ій”®й…ҚзҪ®\n2. content_example.json зҡ„еҶ…е®№з»“жһ„\n3. selectors.yaml зҡ„иҰҶзӣ–жғ…еҶө\n4. жЈҖжҹҘ .venv-xiaodouya иҷҡжӢҹзҺҜеўғжҳҜеҗҰеӯҳеңЁ\n\nи®©жҲ‘з»§з»ӯж·ұе…ҘжЈҖжҹҘгҖӮ","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"read:17","name":"read","arguments":{"path":"/home/yirongbest/.openclaw/workspace/xiaodouya/controller.py","limit":100}},{"type":"toolCall","id":"read:18","name":"read","arguments":{"path":"/home/yirongbest/.openclaw/workspace/xiaodouya/publish_xiaohongshu.py","limit":80}},{"type":"toolCall","id":"exec:19","name":"exec","arguments":{"command":"ls -la /home/yirongbest/.openclaw/workspace/.venv-xiaodouya/bin/python 2>/dev/null && echo \"=== Virtual env exists ===\" || echo \"=== Virtual env NOT found ===\""}}],"api":"openai-completions","provider":"volcengine-plan","model":"kimi-k2.5","usage":{"input":21358,"output":256,"cacheRead":0,"cacheWrite":0,"totalTokens":21614,"cost":{"input":0.0000021358,"output":5.12e-8,"cacheRead":0,"cacheWrite":0,"total":0.000002187}},"stopReason":"toolUse","timestamp":1772257694326}}
{"type":"message","id":"4405cfc5","parentId":"4007435e","timestamp":"2026-02-28T05:48:32.063Z","message":{"role":"toolResult","toolCallId":"read:17","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport base64\nimport json\nimport os\nimport shutil\nimport subprocess\nimport tempfile\nimport time\nfrom pathlib import Path\nfrom typing import Any, Callable, Dict, List, Optional\n\ntry:\n    import yaml\nexcept ImportError:  # pragma: no cover\n    yaml = None\n\nDEFAULT_APP_PATH = r\"C:\\Program Files\\xiaodouya\\ж–°жҰңе°ҸиұҶиҠҪ.exe\"\nDEFAULT_POWERSHELL_EXE = \"/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe\"\nDEFAULT_WIN_PYTHON = r\"C:\\Users\\yuyirong\\AppData\\Local\\Programs\\Python\\Python311\\python.exe\"\nDEFAULT_TIMEOUT_SECONDS = 15\nRETRY_DELAYS = [0.8, 1.6, 3.2]\n\nREQUIRED_SELECTOR_FIELDS = [\n    \"window\",\n    \"entry_xiaohongshu\",\n    \"editor_title\",\n    \"editor_body\",\n    \"tags_input\",\n    \"pre_publish_anchor\",\n    \"confirm_publish_button\",\n]\n\n\nWIN_BRIDGE_SCRIPT = r'''\n\nimport json\nimport os\nimport re\nimport traceback\nfrom pathlib import Path\n\ndef out(payload):\n    print(json.dumps(payload, ensure_ascii=False))\n\ntry:\n    from pywinauto import Application, Desktop\nexcept Exception as exc:\n    out({\"ok\": False, \"error\": \"pywinauto import failed: \" + str(exc)})\n    raise SystemExit(0)\n\npayload = json.loads(os.environ.get(\"XDY_PAYLOAD\", \"{}\"))\n\naction = payload.get(\"action\")\nwindow_strategies = payload.get(\"window\") or []\napp_path = payload.get(\"app_path\")\n\ndef to_selector_used(kind, raw):\n    return {\"kind\": kind, \"raw\": raw}\n\ndef normalize_text(value):\n    try:\n        return str(value or \"\")\n    except Exception:\n        return \"\"\n\ndef find_main_window(strategies):\n    for backend in [\"uia\", \"win32\"]:\n        try:\n            desktop = Desktop(backend=backend)\n            for strategy in strategies:\n                try:\n                    if \"process_id\" in strategy:\n                        spec = strategy[\"process_id\"]\n                        proc_id = spec.get(\"id\")\n                        if proc_id:\n                            try:\n                                app = Application(backend=backend).connect(process=proc_id)\n                                win = app.window()\n                                return win.wrapper_object(), to_selector_used(\"process_id\", spec)\n                            except:\n                                pass\n                    \n                    if \"process_name\" in strategy:\n                        spec = strategy[\"process_name\"]\n                        proc_name = spec.get(\"name\")\n                        if proc_name:\n                            try:\n                                app = Application(backend=backend).connect(process_name=proc_name)\n                                win = app.window()\n                                return win.wrapper_object(), to_selector_used(\"process_name\", spec)\n                            except:\n                                pass\n                    \n                    if \"uia\" in strategy:\n                        spec = strategy[\"uia\"]\n                        kwargs = {}\n                        if spec.get(\"title\"):\n                            kwargs[\"title\"] = spec[\"title\"]\n\n[544 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1772257712062}}
{"type":"message","id":"b1a1b6a2","parentId":"4405cfc5","timestamp":"2026-02-28T05:48:32.067Z","message":{"role":"toolResult","toolCallId":"read:18","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport time\nimport uuid\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional\n\ntry:\n    import yaml\nexcept ImportError:  # pragma: no cover\n    yaml = None\n\nfrom controller import XiaodouyaController\n\nDEFAULT_BASE_DIR = Path(__file__).resolve().parent\nDEFAULT_SELECTORS_PATH = DEFAULT_BASE_DIR / \"selectors.yaml\"\nDEFAULT_EVIDENCE_ROOT = DEFAULT_BASE_DIR / \"evidence\"\n\nSTEP_ORDER = [\n    \"attach_or_start\",\n    \"activate\",\n    \"entry_xiaohongshu\",\n    \"editor_title\",\n    \"editor_body\",\n    \"tags_input\",\n    \"pre_publish_anchor\",\n    \"confirm_publish_button\",\n    \"screenshot_prepublish\",\n    \"publish_click\",\n]\n\n\ndef load_content(path: str | Path) -> Dict[str, Any]:\n    content_path = Path(path)\n    if not content_path.exists():\n        raise FileNotFoundError(f\"content file not found: {content_path}\")\n\n    text = content_path.read_text(encoding=\"utf-8\")\n    suffix = content_path.suffix.lower()\n\n    if suffix == \".json\":\n        data = json.loads(text)\n    elif suffix in {\".yaml\", \".yml\"}:\n        if yaml is None:\n            raise RuntimeError(\"PyYAML is required for YAML content file\")\n        data = yaml.safe_load(text)\n    else:\n        lines = [line.strip() for line in text.splitlines()]\n        non_empty = [line for line in lines if line]\n        title = non_empty[0] if non_empty else \"иҮӘеҠЁеҸ‘еёғж Үйўҳ\"\n        body = \"\\n\".join(non_empty[1:]) if len(non_empty) > 1 else \"иҮӘеҠЁеҸ‘еёғжӯЈж–Ү\"\n        data = {\"title\": title, \"body\": body, \"tags\": []}\n\n    if not isinstance(data, dict):\n        raise ValueError(\"content file must parse to object\")\n\n    tags = data.get(\"tags\", [])\n    if isinstance(tags, str):\n        tags = [tag for tag in tags.split() if tag]\n\n    return {\n        \"title\": str(data.get(\"title\", \"иҮӘеҠЁеҸ‘еёғж Үйўҳ\")),\n        \"body\": str(data.get(\"body\", \"иҮӘеҠЁеҸ‘еёғжӯЈж–Ү\")),\n        \"tags\": tags,\n    }\n\n\nclass WorkflowRunner:\n    def __init__(\n        self,\n        controller: XiaodouyaController,\n        run_id: str,\n        evidence_dir: Path,\n    ) -> None:\n        self.controller = controller\n        self.run_id = run_id\n        self.evidence_dir = evidence_dir\n\n[215 more lines in file. Use offset=81 to continue.]"}],"isError":false,"timestamp":1772257712066}}
