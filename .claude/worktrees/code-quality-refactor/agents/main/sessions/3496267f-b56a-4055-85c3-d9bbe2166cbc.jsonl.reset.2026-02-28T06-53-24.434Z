se, \"preflight\", start, error=f\"powershell not found: {self.powershell_exe} (checked: {wsl_ps})\")\n547:        \"\"\"Invoke Windows Python via PowerShell to execute bridge script.\"\"\"\n550:        temp_name = \"xdy_bridge_\" + uuid.uuid4().hex[:8] + \".py\"\n554:        # Write the bridge script\n562:        wsl_ps = self._win_path_to_wsl(self.powershell_exe)\n610:                \"error\": \"bridge returned non-json output\",\n617:            parsed[\"error\"] = f\"bridge exited with code {process.returncode}\"","cwd":"/home/yirongbest/.openclaw/workspace"},"isError":false,"timestamp":1772259749940}}
