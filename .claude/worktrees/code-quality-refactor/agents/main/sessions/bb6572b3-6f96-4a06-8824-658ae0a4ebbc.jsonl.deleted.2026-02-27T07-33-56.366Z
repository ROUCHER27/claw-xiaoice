{"type":"message","id":"04946f45","parentId":"5b426e77","timestamp":"2026-02-27T06:33:49.274Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在我要创建完整的MCP服务器脚本。这个脚本需要实现以下工具：1. xiaodouya_discover - 发现小豆芽进程\n2. xiaodouya_activate - 激活窗口到前台\n3. xiaodouya_list_controls - 列出UI控件\n4. xiaodouya_click - 点击控件或坐标\n5. xiaodouya_input_text - 输入文本\n6. xiaodouya_screenshot - 截图\n\n我将创建一个完整的Python脚本。","thinkingSignature":"reasoning_content"},{"type":"text","text":"现在创建完整的MCP服务器脚本："},{"type":"toolCall","id":"write:1","name":"write","arguments":{"path":"/home/yirongbest/.openclaw/workspace/xiaodouya_mcp_server.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n小豆芽 MCP Server\n通过MCP协议暴露小豆芽Windows应用的控制能力\n\"\"\"\n\nimport asyncio\nimport json\nimport sys\nimport logging\nimport subprocess\nimport os\nfrom typing import Optional, Dict, Any, List\nfrom dataclasses import dataclass\n\n# MCP SDK imports\nfrom mcp.server import Server\nfrom mcp.server.stdio import stdio_server\nfrom mcp.types import Tool, TextContent, ImageContent, ErrorContent\n\n# Configure logging\nlogging.basicConfig(\n    level=logging.INFO,\n    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',\n    handlers=[logging.StreamHandler(sys.stderr)]\n)\nlogger = logging.getLogger(\"xiaodouya-mcp\")\n\n# Constants\nXIAODOUYA_PATH = r\"C:\\Program Files\\xiaodouya\\新版小豆芽.exe\"\nDEFAULT_PID = 19944\nPOWERSHELL_PATH = r\"/mnt/c/Windows/System32/windowspowershell/v1.0/powershell.exe\"\n\n\n@dataclass\nclass ProcessInfo:\n    \"\"\"小豆芽进程信息\"\"\"\n    pid: int\n    title: str\n    path: str\n    status: str\n\n\nclass XiaodouyaController:\n    \"\"\"小豆芽控制器 - 封装所有PowerShell和UIA操作\"\"\"\n    \n    def __init__(self):\n        self.powershell = POWERSHELL_PATH\n        \n    def _run_powershell(self, script: str, timeout: int = 30) -> tuple:\n        \"\"\"执行PowerShell脚本并返回结果\"\"\"\n        try:\n            # 使用UTF-8编码\n            encoded_script = script.encode('utf-8').decode('utf-8')\n            \n            cmd = [\n                self.powershell,\n                \"-NoProfile\",\n                \"-ExecutionPolicy\", \"Bypass\",\n                \"-Command\", encoded_script\n            ]\n            \n            logger.debug(f\"Running PowerShell command (timeout={timeout}s)\")\n            \n            result = subprocess.run(\n                cmd,\n                capture_output=True,\n                text=True,\n                timeout=timeout,\n                encoding='utf-8',\n                errors='replace'\n            )\n            \n            return result.returncode, result.stdout, result.stderr\n            \n        except subprocess.TimeoutExpired:\n            logger.error(\"PowerShell command timed out\")\n            return -1, \"\", \"Timeout\"\n        except Exception as e:\n            logger.error(f\"Error running PowerShell: {e}\")\n            return -1, \"\", str(e)\n    \n    def discover_processes(self) -> List[ProcessInfo]:\n        \"\"\"发现所有小豆芽进程\"\"\"\n        script = '''\nAdd-Type @\"\nusing System;\nusing System.Runtime.InteropServices;\npublic class WindowInfo {\n    [DllImport(\"user32.dll\")]\n    public static extern bool IsWindowVisible(IntPtr hWnd);\n    [DllImport(\"user32.dll\")]\n    public static extern bool GetWindowText(IntPtr hWnd, System.Text.StringBuilder lpString, int nMaxCount);\n    [DllImport(\"user32.dll\")]\n    public static extern int GetWindowThreadProcessId(IntPtr hWnd, out int lpdwProcessId);\n}\n\"@\n\n$processes = Get-Process | Where-Object { $_.ProcessName -like \"*小豆芽*\" -or $_.ProcessName -like \"*xiaodouya*\" }\n$result = @()\n\nforeach ($proc in $processes) {\n    $hwnd = (Get-Process -Id $proc.Id).MainWindowHandle\n    $title = \"\"\n    if ($hwnd -ne 0) {\n        $sb = New-Object System.Text.StringBuilder 256\n        [void][WindowInfo]::GetWindowText($hwnd, $sb, 256)\n        $title = $sb.ToString()\n    }\n    \n    $status = if ($proc.Responding) { \"Running\" } else { \"Not Responding\" }\n    if ($hwnd -eq 0) { $status = \"No Window\" }\n    \n    $result += [PSCustomObject]@{\n        PID = $proc.Id\n        Title = $title\n        Path = $proc.Path\n        Status = $status\n    }\n}\n\n$result | ConvertTo-Json -Compress\n'''\n        \n        returncode, stdout, stderr = self._run_powershell(script)\n        \n        if returncode != 0:\n            logger.error(f\"Failed to discover processes: {stderr}\")\n            return []\n        \n        try:\n            data = json.loads(stdout)\n            if not isinstance(data, list):\n                data = [data] if data else []\n            \n            processes = []\n            for item in data:\n                if item:\n                    processes.append(ProcessInfo(\n                        pid=item.get('PID', 0),\n                        title=item.get('Title', ''),\n                        path=item.get('Path', ''),\n                        status=item.get('Status', 'Unknown')\n                    ))\n            return processes\n        except Exception as e:\n            logger.error(f\"Error parsing process data: {e}\")\n            return []\n    \n    def activate_window(self, pid: Optional[int] = None) -> bool:\n        \"\"\"激活窗口到前台\"\"\"\n        target_pid = pid or DEFAULT_PID\n        \n        script = f'''\nAdd-Type @\"\nusing System;\nusing System.Runtime.InteropServices;\npublic class WindowActivator {{\n    [DllImport(\"user32.dll\")]\n    public static extern bool SetForegroundWindow(IntPtr hWnd);\n    [DllImport(\"user32.dll\")]\n    public static extern bool ShowWindowAsync(IntPtr hWnd, int nCmdShow);\n    [DllImport(\"user32.dll\")]\n    public static extern bool IsIconic(IntPtr hWnd);\n    [DllImport(\"user32.dll\")]\n    public static extern int GetWindowThreadProcessId(IntPtr hWnd, out int lpdwProcessId);\n    \n    public const int SW_RESTORE = 9;\n    public const int SW_SHOW = 5;\n}}\n\"@\n\n$targetPid = {target_pid}\n$found = $false\n\nGet-Process | Where-Object {{ $_.Id -eq $targetPid }} | ForEach-Object {{\n    $hwnd = $_.MainWindowHandle\n    if ($hwnd -ne 0) {{\n        if ([WindowActivator]::IsIconic($hwnd)) {{\n            [void][WindowActivator]::ShowWindowAsync($hwnd, [WindowActivator]::SW_RESTORE)\n        }}\n        [void][WindowActivator]::ShowWindowAsync($hwnd, [WindowActivator]::SW_SHOW)\n        Start-Sleep -Milliseconds 100\n        $result = [WindowActivator]::SetForegroundWindow($hwnd)\n        if ($result) {{\n            $found = $true\n            \"SUCCESS\"\n        }} else {{\n            \"FAILED_TO_FOREGROUND\"\n        }}\n    }} else {{\n        \"NO_WINDOW_HANDLE\"\n    }}\n}}\n\nif (-not $found) {{\n    \"PROCESS_NOT_FOUND\"\n}}\n'''\n        \n        returncode, stdout, stderr = self._run_powershell(script)\n        \n        if returncode == 0 and \"SUCCESS\" in stdout:\n            logger.info(f\"Successfully activated window for PID {target_pid}\")\n            return True\n        else:\n            logger.error(f\"Failed to activate window: {stdout} {stderr}\")\n            return False\n    \n    def list_controls(self, pid: Optional[int] = None, max_depth: int = 2) -> List[Dict]:\n        \"\"\"列出窗口中的所有UI控件\"\"\"\n        target_pid = pid or DEFAULT_PID\n        \n        script = f'''\n[System.Reflection.Assembly]::LoadWithPartialName(\"UIAutomationClient\") | Out-Null\n\n$targetPid = {target_pid}\n$maxDepth = {max_depth}\n\nfunction Get-UIControls {{\n    param($element, $currentDepth = 0, $parentPath = \"\")\n    \n    if ($currentDepth -gt $maxDepth) {{ return @() }}\n    if ($element -eq $null) {{ return @() }}\n    \n    $result = @()\n    \n    try {{\n        # Get control properties\n        $name = \"\"\n        $automationId = \"\"\n        $controlType = \"\"\n        $className = \"\"\n        $bounds = $null\n        \n        try {{ $name = $element.Current.Name }} catch {{ }}\n        try {{ $automationId = $element.Current.AutomationId }} catch {{ }}\n        try {{ $controlType = $element.Current.ControlType.ProgrammaticName }} catch {{ }}\n        try {{ $className = $element.Current.ClassName }} catch {{ }}\n        try {{ $bounds = $element.Current.BoundingRectangle }} catch {{ }}\n        \n        $controlInfo = @{{\n            Name = $name\n            AutomationId = $automationId\n            ControlType = $controlType\n            ClassName = $className\n            Bounds = if ($bounds) {{ @{{ Left=$bounds.Left; Top=$bounds.Top; Right=$bounds.Right; Bottom=$bounds.Bottom }} }} else {{ $null }}\n            Depth = $currentDepth\n            Children = @()\n        }}\n        \n        # Get children\n        try {{\n            $condition = [System.Windows.Automation.Condition]::TrueCondition\n            $children = $element.FindAll([System.Windows.Automation.TreeScope]::Children, $condition)\n            \n            for ($i = 0; $i -lt $children.Count; $i++) {{\n                $childControls = Get-UIControls -element $children[$i] -currentDepth ($currentDepth + 1) -parentPath \"$parentPath/$name\"\n                $controlInfo.Children += $childControls\n            }}\n        }} catch {{ }}\n        \n        $result += $controlInfo\n        \n    }} catch {{\n        # Silently handle errors\n    }}\n    \n    return $result\n}}\n\n# Find the process window\n$process = Get-Process | Where-Object {{ $_.Id -eq $targetPid }} | Select-Object -First 1\n\nif (-not $process) {{\n    ConvertTo-Json @{{ Error = \"Process not found\" }} -Compress\n    exit\n}}\n\n# Get the main window handle\n$hwnd = $process.MainWindowHandle\n\nif ($hwnd -eq 0) {{\n    ConvertTo-Json @{{ Error = \"No main window found\" }} -Compress\n    exit\n}}\n\n# Create automation element from handle\n$automation = [System.Windows.Automation.AutomationElement]::FromHandle($hwnd)\n\nif (-not $automation) {{\n    ConvertTo-Json @{{ Error = \"Failed to create automation element\" }} -Compress\n    exit\n}}\n\n# Get all controls\n$controls = Get-UIControls -element $automation -currentDepth 0\n\n# Convert to JSON\n$controls | ConvertTo-Json -Depth 10 -Compress\n'''\n        \n        returncode, stdout, stderr = self._run_powershell(script, timeout=60)\n        \n        if returncode != 0:\n            logger.error(f\"Failed to list controls: {stderr}\")\n            return []\n        \n        try:\n            data = json.loads(stdout)\n            if isinstance(data, dict) and \"Error\" in data:\n                logger.error(f\"Error from PowerShell: {data['Error']}\")\n                return []\n            return data if isinstance(data, list) else [data]\n        except Exception as e:\n            logger.error(f\"Error parsing controls: {e}\")\n            return []\n    \n    def click_control(self, pid: Optional[int] = None, control_name: Optional[str] = None, \n                      x: Optional[int] = None, y: Optional[int] = None) -> bool:\n        \"\"\"点击指定控件或坐标\"\"\"\n        target_pid = pid or DEFAULT_PID\n        \n        if control_name:\n            # 点击指定名称的控件\n            script = f'''\n[System.Reflection.Assembly]::LoadWithPartialName(\"UIAutomationClient\") | Out-Null\n\n$targetPid = {target_pid}\n$controlName = \"{control_name}\"\n\n# Find the process\n$process = Get-Process | Where-Object {{ $_.Id -eq $targetPid }} | Select-Object -First 1\nif (-not $process) {{\n    \"PROCESS_NOT_FOUND\"\n    exit\n}}\n\n$hwnd = $process.MainWindowHandle\nif ($hwnd -eq 0) {{\n    \"NO_WINDOW\"\n    exit\n}}\n\n# Get automation element\n$automation = [System.Windows.Automation.AutomationElement]::FromHandle($hwnd)\nif (-not $automation) {{\n    \"AUTOMATION_FAILED\"\n    exit\n}}\n\n# Find control by name\n$condition = [System.Windows.Automation.PropertyCondition]::new(\n    [System.Windows.Automation.AutomationElement]::NameProperty, \n    $controlName\n)\n$control = $automation.FindFirst([System.Windows.Automation.TreeScope]::Descendants, $condition)\n\nif (-not $control) {{\n    \"CONTROL_NOT_FOUND\"\n    exit\n}}\n\n# Get clickable point\n$clickablePoint = $control.Current.ClickablePoint\n\n# Use Windows API to click\nAdd-Type @\"\nusing System;\nusing System.Runtime.InteropServices;\npublic class MouseClick {{\n    [DllImport(\"user32.dll\")]\n    public static extern bool SetCursorPos(int x, int y);\n    [DllImport(\"user32.dll\")]\n    public static extern void mouse_event(int dwFlags, int dx, int dy, int dwData, IntPtr dwExtraInfo);\n    public const int MOUSEEVENTF_LEFTDOWN = 0x02;\n    public const int MOUSEEVENTF_LEFTUP = 0x04;\n}}\n\"@\n\n[void][MouseClick]::SetCursorPos([int]$clickablePoint.X, [int]$clickablePoint.Y)\nStart-Sleep -Milliseconds 50\n[void][MouseClick]::mouse_event([MouseClick]::MOUSEEVENTF_LEFTDOWN, 0, 0, 0, 0)\nStart-Sleep -Milliseconds 50\n[void][MouseClick]::mouse_event([MouseClick]::MOUSEEVENTF_LEFTUP, 0, 0, 0, 0)\n\n\"SUCCESS\"\n'''\n        else:\n            # 点击指定坐标\n            if x is None or y is None:\n                logger.error(\"Must provide either control_name or x,y coordinates\")\n                return False\n            \n            script = f'''\nAdd-Type @\"\nusing System;\nusing System.Runtime.InteropServices;\npublic class MouseClick {{\n    [DllImport(\"user32.dll\")]\n    public static extern bool SetCursorPos(int x, int y);\n    [DllImport(\"user32.dll\")]\n    public static extern void mouse_event(int"}}],"api":"openai-completions","provider":"volcengine-plan","model":"kimi-k2.5","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"aborted","timestamp":1772173811148,"errorMessage":"Request was aborted"}}
